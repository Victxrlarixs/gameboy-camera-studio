---
import "../../styles/components/LabBook.css";
---

<div id="lab-book-overlay" class="fixed inset-0 z-[300] flex items-center justify-center bg-black/80 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-500 scale-95 overflow-hidden">
    <div class="matte-plastic w-[90%] max-w-[1000px] h-[85vh] p-8 sm:p-12 rounded-[24px_24px_120px_24px] border-t-2 border-l-2 border-white/40 border-r-[12px] border-b-[12px] border-black/40 shadow-2xl flex flex-col relative">

<div class="absolute left-[-15px] top-[10%] bottom-[15%] w-8 flex flex-col justify-around pointer-events-none">
            {[...Array(6)].map((_, i) => (
                <div class="w-12 h-6 bg-gradient-to-r from-zinc-400 to-zinc-600 rounded-full shadow-lg border border-black/20 translate-x-1/2"></div>
            ))}
        </div>

<div class="flex justify-between items-center border-b-2 border-black/10 pb-6 mb-8">
            <div class="flex flex-col">
                <span class="text-[14px] font-pixel text-[#302080] italic uppercase tracking-tighter embossed-text">Lab Asset Inventory</span>
                <span class="text-[8px] font-pixel text-zinc-500 uppercase mt-1">Classification: Confidential / Internal Use Only</span>
            </div>
            <div class="flex gap-4">
                 <div class="text-[10px] font-pixel text-[#302080] opacity-60">STORAGE: <span id="lab-storage-stats">0/30</span></div>
                 <button id="close-lab-book" class="w-10 h-10 bg-zinc-600 rounded-full shadow-md active:translate-y-1 transition-all flex items-center justify-center border-t border-white/20">
                    <span class="text-white text-[12px]">×</span>
                 </button>
            </div>
        </div>

<div id="lab-grid" class="flex-1 overflow-y-auto pr-4 custom-scrollbar-v grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 content-start p-2">
            
        </div>

<div class="mt-8 pt-6 border-t-2 border-black/10 flex justify-between items-center">
            <span class="text-[8px] font-pixel text-zinc-400 uppercase italic">DMG-CAM-LAB-BINDER-V1</span>
            <div class="flex gap-4">
                 <span class="text-[8px] font-pixel text-[#3a2a6b] animate-pulse">SYSTEM READY</span>
            </div>
        </div>
    </div>
    <script>
        import { setupLabBookLogic } from "../../lib/labbook-logic";
        setupLabBookLogic();
    </script>
</div>
