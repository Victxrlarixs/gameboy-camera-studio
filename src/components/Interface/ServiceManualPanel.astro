---
import "../../styles/components/StudioSidePanel.css";
---
<div class="manual-panel hidden xl:flex flex-col gap-6 w-[340px] p-8 m-4 rounded-[20px_20px_20px_100px] border-t-2 border-l-2 border-white/30 border-r-[10px] border-b-[10px] border-black/30 matte-plastic shadow-[20px_20px_60px_rgba(0,0,0,0.5),inset_3px_3px_0_rgba(255,255,255,0.2)] h-[calc(100vh-40px)] overflow-y-auto relative">
    <!-- Panel Grip Texture (Mirrored) -->
    <div class="absolute top-10 left-2 w-1 h-32 flex flex-col gap-2 opacity-20">
        <div class="w-full h-full bg-black rounded-full"></div>
        <div class="w-full h-full bg-black rounded-full"></div>
        <div class="w-full h-full bg-black rounded-full"></div>
    </div>
    <!-- SERVICE HEADER -->
    <div class="flex flex-col gap-1 border-b-4 border-black/20 pb-4 shrink-0">
        <h2 class="text-[12px] font-pixel text-[#3a2a6b] italic opacity-80 uppercase tracking-tighter">
            Service Manual <span class="text-[8px] not-italic opacity-60">REF-89</span>
        </h2>
        <div class="h-1 bg-black/10 w-full"></div>
    </div>

    <!-- CONTROL SCHEME (Dymo Labels Style) -->
    <div class="space-y-6">
        <label class="text-[9px] font-pixel text-[#302080] opacity-70 uppercase">Operation Keys</label>
        
        <div class="grid grid-cols-1 gap-4">
            <!-- Key Tag: A -->
            <div class="flex items-center gap-4 group">
                <div class="w-10 h-6 bg-black/80 rounded-xs flex items-center justify-center border-b-2 border-white/10 shadow-lg">
                    <span class="text-[8px] font-pixel text-white">Z</span>
                </div>
                <span class="text-[7px] font-pixel text-zinc-600 uppercase tracking-widest group-hover:text-[#a01050] transition-colors">Action A / Shoot</span>
            </div>

            <!-- Key Tag: B -->
            <div class="flex items-center gap-4 group">
                <div class="w-10 h-6 bg-black/80 rounded-xs flex items-center justify-center border-b-2 border-white/10 shadow-lg">
                    <span class="text-[8px] font-pixel text-white">X</span>
                </div>
                <span class="text-[7px] font-pixel text-zinc-600 uppercase tracking-widest group-hover:text-[#a01050] transition-colors">Action B / Back</span>
            </div>

            <!-- Key Tag: Start -->
            <div class="flex items-center gap-4 group">
                <div class="w-14 h-6 bg-black/80 rounded-xs flex items-center justify-center border-b-2 border-white/10 shadow-lg">
                    <span class="text-[6px] font-pixel text-white uppercase">Enter</span>
                </div>
                <span class="text-[7px] font-pixel text-zinc-600 uppercase tracking-widest group-hover:text-[#a01050] transition-colors">Start / Menu</span>
            </div>

            <!-- Key Tag: Select -->
            <div class="flex items-center gap-4 group">
                <div class="w-14 h-6 bg-black/80 rounded-xs flex items-center justify-center border-b-2 border-white/10 shadow-lg">
                    <span class="text-[6px] font-pixel text-white uppercase">Shift</span>
                </div>
                <span class="text-[7px] font-pixel text-zinc-600 uppercase tracking-widest group-hover:text-[#a01050] transition-colors">Select / Palette</span>
            </div>
        </div>
    </div>

    <!-- HARDWARE DIAGNOSTICS (Functional) -->
    <div class="space-y-4 pt-8 border-t-2 border-black/10">
        <label class="text-[9px] font-pixel text-[#302080] opacity-70 uppercase block text-center">Diagnostics</label>
        
        <div class="p-4 bg-black/10 rounded-sm border border-black/20 space-y-4 shadow-[inset_2px_2px_4px_rgba(0,0,0,0.2)]">
             <!-- Status bar: SRAM (Photos) -->
             <div class="space-y-2">
                <div class="flex justify-between items-end">
                    <span class="text-[7px] font-pixel text-zinc-500 uppercase">SRAM Storage</span>
                    <span id="diag-photo-count" class="text-[8px] font-pixel text-[#302080]">0/30</span>
                </div>
                <div class="w-full h-2 bg-black/30 rounded-full overflow-hidden border border-white/5">
                    <div id="diag-photo-bar" class="h-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.4)] transition-all duration-500" style="width: 0%"></div>
                </div>
             </div>
             
             <!-- Status bar: Print Queue -->
             <div class="space-y-2">
                <div class="flex justify-between items-end">
                    <span class="text-[7px] font-pixel text-zinc-500 uppercase">Print Buffer</span>
                    <span id="diag-print-status" class="text-[7px] font-pixel text-zinc-400">IDLE</span>
                </div>
                <div class="flex gap-1 overflow-hidden" id="diag-buffer-grid">
                    {[...Array(12)].map((_, i) => (
                        <div class="diag-buffer-cell w-3 h-3 bg-black/20 border border-black/10 rounded-xs transition-colors duration-200"></div>
                    ))}
                </div>
             </div>
        </div>
    </div>

    <!-- COPYRIGHT PLATE -->
    <div class="mt-auto p-4 bg-black/5 border border-black/10 rounded-sm">
        <p class="text-[5px] font-pixel leading-relaxed text-zinc-500 uppercase tracking-tighter">
            Game Boy Camera Studio<br>
            Engineering Dept.<br>
            Model: DMG-CAMERA-2026<br>
            Serial: #00042-89
        </p>
    </div>
</div>

<script>
    import { PhotoStore } from "../../store/photos";
    
    function updateDiagnostics() {
        const photos = PhotoStore.getPhotos();
        const count = photos.length;
        const max = 30; // Standard GB Camera capacity
        const percent = Math.min((count / max) * 100, 100);
        
        const countLabel = document.getElementById('diag-photo-count');
        const bar = document.getElementById('diag-photo-bar');
        
        if (countLabel) countLabel.innerText = `${count}/${max}`;
        if (bar) bar.style.width = `${percent}%`;

        // If storage is full, change bar color to alert
        if (count >= max && bar) {
            bar.classList.replace('bg-emerald-500', 'bg-red-500');
        } else if (bar) {
            bar.classList.add('bg-emerald-500');
            bar.classList.remove('bg-red-500');
        }
    }

    // React to photo saves
    window.addEventListener('gb-photo-saved', updateDiagnostics);

    // Print Buffer Visualization
    window.addEventListener('gb-print-start', () => {
        const label = document.getElementById('diag-print-status');
        if (label) {
            label.innerText = 'WAIT...';
            label.classList.add('animate-pulse', 'text-amber-500');
            label.classList.remove('text-zinc-400');
        }
        
        const cells = document.querySelectorAll('.diag-buffer-cell');
        cells.forEach((cell, i) => {
            setTimeout(() => {
                (cell as HTMLElement).style.backgroundColor = 'rgba(245, 158, 11, 0.6)';
            }, i * 150);
        });
    });

    window.addEventListener('gb-print-end', () => {
        const label = document.getElementById('diag-print-status');
        if (label) {
            label.innerText = 'IDLE';
            label.classList.remove('animate-pulse', 'text-amber-500');
            label.classList.add('text-zinc-400');
        }
        
        const cells = document.querySelectorAll('.diag-buffer-cell');
        cells.forEach((cell) => {
            (cell as HTMLElement).style.backgroundColor = '';
        });
    });

    // Run on init
    updateDiagnostics();
</script>
