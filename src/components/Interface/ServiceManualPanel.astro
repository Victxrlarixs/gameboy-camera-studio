---
import "../../styles/components/StudioSidePanel.css";
---
<div class="manual-panel flex flex-col gap-6 p-8 overflow-y-auto relative">

<div class="flex justify-between items-start border-b border-black/10 shadow-[0_1px_0_rgba(255,255,255,0.7)] pb-4 shrink-0">
    <div class="flex flex-col gap-1">
        <h2 class="text-[13px] font-pixel text-[#3a2a6b] italic uppercase tracking-tighter embossed-text">
            Service Console
        </h2>
        <div class="flex gap-1.5 mt-1">
            <div class="flex grow h-1 bg-black/5 rounded-full shadow-inner"></div>
            <div class="w-12 h-1 bg-[#3a2a6b]/30 rounded-full"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-emerald-600 shadow-md border border-black/20"></div>
        </div>
    </div>
    <button id="close-service-panel" class="lg:hidden w-8 h-8 rounded-full bg-black/5 flex items-center justify-center border border-black/10 active:scale-90 transition-transform">
        <span class="text-zinc-600 text-lg">×</span>
    </button>
</div>

<div class="space-y-4 shrink-0 pt-2">
        <label class="text-[8px] font-pixel text-[#3a2a6b]/70 uppercase tracking-[0.2em] mb-2 block">Key Assignment</label>
        
        <div class="grid grid-cols-2 gap-3 p-3 bg-black/5 rounded-xl border border-black/10 shadow-inner">
            
            <!-- A Button -->
            <div data-action="a" class="flex flex-col items-center gap-2 group bg-black/5 p-3 rounded-xl border border-black/5 hover:bg-[#a01050]/10 hover:border-[#a01050]/30 transition-all cursor-pointer">
                <div class="w-12 h-8 bg-[#a01050] rounded-xs flex items-center justify-center border-t border-white/40 border-r-2 border-b-2 border-black/40 shadow-md group-active:translate-y-px group-active:border-b group-active:shadow-sm">
                    <span class="text-[10px] font-pixel text-white drop-shadow-[0_1px_0_rgba(0,0,0,0.5)]">Z</span>
                </div>
                <div class="flex flex-col items-center">
                    <span class="text-[7px] font-pixel text-[#302080]/80 uppercase">A / SHOOT</span>
                </div>
            </div>

            <!-- B Button -->
            <div data-action="b" class="flex flex-col items-center gap-2 group bg-black/5 p-3 rounded-xl border border-black/5 hover:bg-[#a01050]/10 hover:border-[#a01050]/30 transition-all cursor-pointer">
                <div class="w-12 h-8 bg-[#a01050] rounded-xs flex items-center justify-center border-t border-white/40 border-r-2 border-b-2 border-black/40 shadow-md group-active:translate-y-px group-active:border-b group-active:shadow-sm">
                    <span class="text-[10px] font-pixel text-white drop-shadow-[0_1px_0_rgba(0,0,0,0.5)]">X</span>
                </div>
                <div class="flex flex-col items-center">
                    <span class="text-[7px] font-pixel text-[#302080]/80 uppercase">B / BACK</span>
                </div>
            </div>

            <!-- START Button -->
            <div data-action="start" class="flex flex-col items-center gap-2 group bg-black/5 p-3 rounded-xl border border-black/5 hover:bg-zinc-700/10 hover:border-zinc-700/30 transition-all cursor-pointer">
                <div class="w-12 h-8 bg-zinc-700 rounded-md flex items-center justify-center border-t border-white/30 border-r-2 border-b-2 border-black/60 shadow-md group-active:translate-y-px group-active:border-b group-active:shadow-sm px-2">
                    <span class="text-[6px] font-pixel text-white uppercase drop-shadow-[0_1px_0_rgba(0,0,0,0.5)] opacity-90">ENTER</span>
                </div>
                <div class="flex flex-col items-center">
                    <span class="text-[7px] font-pixel text-[#302080]/80 uppercase">START</span>
                </div>
            </div>

             <!-- SELECT Button -->
            <div data-action="select" class="flex flex-col items-center gap-2 group bg-black/5 p-3 rounded-xl border border-black/5 hover:bg-zinc-700/10 hover:border-zinc-700/30 transition-all cursor-pointer">
                <div class="w-12 h-8 bg-zinc-700 rounded-md flex items-center justify-center border-t border-white/30 border-r-2 border-b-2 border-black/60 shadow-md group-active:translate-y-px group-active:border-b group-active:shadow-sm px-2">
                    <span class="text-[5px] font-pixel text-white uppercase drop-shadow-[0_1px_0_rgba(0,0,0,0.5)] opacity-90">SHIFT</span>
                </div>
                <div class="flex flex-col items-center">
                    <span class="text-[7px] font-pixel text-[#302080]/80 uppercase">SELECT</span>
                </div>
            </div>

            <!-- Arrows Section -->
             <div class="col-span-2 grid grid-cols-4 gap-2 mt-2">
                {['up', 'down', 'left', 'right'].map((dir) => (
                    <div data-action={dir} class="flex flex-col items-center justify-center gap-1.5 group bg-black/5 p-2 rounded-lg border border-black/5 hover:bg-zinc-800/10 transition-all cursor-pointer">
                        <div class="w-8 h-8 bg-zinc-800 rounded-sm flex items-center justify-center border-t border-white/10 border-r-2 border-b-2 border-black/60 shadow-md group-active:translate-y-px group-active:border-b">
                            <span class="text-[10px] text-white/80">
                                {dir === 'up' ? '↑' : dir === 'down' ? '↓' : dir === 'left' ? '←' : '→'}
                            </span>
                        </div>
                        <span class="text-[5px] font-pixel text-[#3a2a6b]/50 uppercase">
                            {dir === 'up' || dir === 'down' ? 'BRIGHT' : 'CONTRAST'}
                        </span>
                    </div>
                ))}
             </div>
        </div>
    </div>

<div class="space-y-4 shrink-0 pt-4 border-t border-black/10 shadow-[inset_0_1px_0_rgba(255,255,255,0.7)] mt-4">
        <label class="text-[8px] font-pixel text-[#3a2a6b]/70 uppercase tracking-[0.2em] mb-2 block">Real-Time Diag</label>
        
        <div class="p-4 bg-black/5 rounded-xl border border-black/10 shadow-inner space-y-5">
             
             <div class="space-y-2.5">
                <div class="flex justify-between items-end border-b border-white/5 pb-1">
                    <span class="text-[6px] font-pixel text-zinc-500 uppercase">SRAM Photo Storage</span>
                    <span id="diag-photo-count" class="text-[8px] font-pixel text-white opacity-80">0/30</span>
                </div>
                <div class="w-full h-2.5 bg-black/60 rounded-full overflow-hidden border border-white/5 shadow-inner">
                    <div id="diag-photo-bar" class="h-full bg-emerald-400 shadow-[0_0_8px_rgba(52,211,153,0.8),inset_0_1px_0_rgba(255,255,255,0.5)] transition-all duration-500" style="width: 0%"></div>
                </div>
             </div>

<div class="space-y-2.5">
                <div class="flex justify-between items-end border-b border-white/5 pb-1">
                    <span class="text-[6px] font-pixel text-zinc-500 uppercase">Parallel Print Buffer</span>
                    <span id="diag-print-status" class="text-[6px] font-pixel text-emerald-400">STATUS: READY</span>
                </div>
                <div class="flex gap-1.5 p-1 bg-black/20 rounded shadow-inner" id="diag-buffer-grid">
                    {[...Array(12)].map((_, i) => (
                        <div class="diag-buffer-cell w-3.5 h-3.5 bg-black/40 border border-black/60 rounded-xs"></div>
                    ))}
                </div>
             </div>
        </div>
    </div>

    <!-- Housing Configuration -->
    <div class="space-y-4 shrink-0 pt-4 border-t border-black/10 shadow-[inset_0_1px_0_rgba(255,255,255,0.7)] mt-4">
        <label class="text-[8px] font-pixel text-[#3a2a6b]/70 uppercase tracking-[0.2em] mb-2 block">Housing Configuration</label>
        <div class="grid grid-cols-2 gap-3">
            <button id="skin-default-btn" class="flex flex-col items-center gap-2 p-3 bg-black/5 rounded-xl border border-black/10 hover:bg-white/5 transition-all group skin-state-btn active-skin">
                <div class="w-12 h-10 bg-[#9c9e9d] rounded-sm shadow-md border-t-2 border-white/40"></div>
                <span class="text-[6px] font-pixel text-[#3a2a6b]/80 uppercase">Classic DMG</span>
            </button>
            <button id="skin-transparent-btn" class="flex flex-col items-center gap-2 p-3 bg-black/5 rounded-xl border border-black/10 hover:bg-white/5 transition-all group skin-state-btn">
                <div class="w-12 h-10 bg-[#9c9e9d]/20 backdrop-blur-[2px] rounded-sm shadow-md border-t-2 border-white/30 relative overflow-hidden">
                    <div class="absolute inset-2 bg-[#1a4a1a]/40 rounded-[1px] border-[0.5px] border-[#ffd700]/20"></div>
                </div>
                <span class="text-[6px] font-pixel text-[#3a2a6b]/80 uppercase">Transparent</span>
            </button>
        </div>
    </div>

    <!-- Lab Buffer -->
    <div class="space-y-4 shrink-0 pt-8 pb-8 border-t border-black/10 shadow-[inset_0_1px_0_rgba(255,255,255,0.7)] mt-4">
        <div class="flex justify-between items-center px-1">
            <label class="text-[8px] font-pixel text-[#3a2a6b]/70 uppercase tracking-widest">Lab Buffer</label>
            <div class="w-6 h-1 bg-black/10 rounded-full"></div>
        </div>
        <div class="relative p-1 debossed-panel rounded-lg shadow-[inset_0_2px_10px_rgba(0,0,0,0.1)] border-t border-black/20">
             <div id="recent-photos" class="flex gap-2 overflow-x-auto overflow-y-hidden p-2 min-h-[90px] rounded-sm custom-scrollbar-h">
                <div class="w-16 h-16 shrink-0 bg-black/20 border border-black/30 rounded-sm flex items-center justify-center relative shadow-inner">
                     <span class="text-[5px] font-pixel text-zinc-700 uppercase">Empty</span>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    import { PhotoStore } from "../../store/photos";
    import { AppStore } from "../../store/app";
    
    function updateDiagnostics() {
        const photos = PhotoStore.getPhotos();
        const count = photos.length;
        const max = 30;
        const percent = Math.min((count / max) * 100, 100);
        
        const countLabel = document.getElementById('diag-photo-count');
        const bar = document.getElementById('diag-photo-bar');
        const container = countLabel?.closest('.debossed-panel') as any;
        if (container && !container.dataset.hasListener) {
            container.style.cursor = 'pointer';
            container.addEventListener('click', () => {
                AppStore.setMode('VIEW');
                AppStore.playSound('click');
            });
            container.dataset.hasListener = 'true';
        }
        
        if (countLabel) countLabel.innerText = `${count}/${max}`;
        if (bar) bar.style.width = `${percent}%`;
        if (count >= max && bar) {
            bar.classList.add('bg-red-500');
            bar.classList.remove('bg-emerald-500');
        } else if (bar) {
            bar.classList.add('bg-emerald-500');
            bar.classList.remove('bg-red-500');
        }
    }
    window.addEventListener('gb-photo-saved', updateDiagnostics);
    window.addEventListener('gb-photo-deleted', updateDiagnostics);
    window.addEventListener('gb-print-start', () => {
        const label = document.getElementById('diag-print-status');
        if (label) {
            label.innerText = 'WAIT...';
            label.classList.add('animate-pulse', 'text-amber-500');
            label.classList.remove('text-zinc-400');
        }
        
        const cells = document.querySelectorAll('.diag-buffer-cell');
        cells.forEach((cell: any, i) => {
            setTimeout(() => {
                cell.style.backgroundColor = 'rgba(245, 158, 11, 0.6)';
            }, i * 150);
        });
    });

    window.addEventListener('gb-print-end', () => {
        const label = document.getElementById('diag-print-status');
        if (label) {
            label.innerText = 'IDLE';
            label.classList.remove('animate-pulse', 'text-amber-500');
            label.classList.add('text-zinc-400');
        }
        
        const cells = document.querySelectorAll('.diag-buffer-cell');
        cells.forEach((cell: any) => {
            cell.style.backgroundColor = '';
        });
    });
    updateDiagnostics();

    // Bind Key Assignment cards to AppStore actions
    document.querySelectorAll('[data-action]').forEach(el => {
        el.addEventListener('click', () => {
            const action = el.getAttribute('data-action');
            if (action) {
                AppStore.handleInput(action);
                
                // Visual feedback
                el.classList.add('scale-95', 'brightness-125');
                setTimeout(() => el.classList.remove('scale-95', 'brightness-125'), 100);
            }
        });
    });

    // Bind Skin Buttons
    const defaultBtn = document.getElementById('skin-default-btn');
    const transparentBtn = document.getElementById('skin-transparent-btn');

    function updateSkinButtons() {
        const currentSkin = AppStore.state.skin;
        if (currentSkin === 'DEFAULT') {
            defaultBtn?.classList.add('active-skin');
            transparentBtn?.classList.remove('active-skin');
        } else {
            transparentBtn?.classList.add('active-skin');
            defaultBtn?.classList.remove('active-skin');
        }
    }

    defaultBtn?.addEventListener('click', () => {
        if (AppStore.state.skin === 'DEFAULT') return;
        AppStore.toggleSkin();
        updateSkinButtons();
    });

    transparentBtn?.addEventListener('click', () => {
        if (AppStore.state.skin === 'TRANSPARENT') return;
        AppStore.toggleSkin();
        updateSkinButtons();
    });

    window.addEventListener('gb-state-change', updateSkinButtons);
    updateSkinButtons();

    // Mobile Close
    document.getElementById('close-service-panel')?.addEventListener('click', () => {
        document.querySelector('.manual-panel')?.classList.remove('mobile-active');
        AppStore.playSound('click');
    });
</script>
