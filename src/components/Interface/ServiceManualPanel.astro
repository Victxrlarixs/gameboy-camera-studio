---
---
<div class="manual-panel hidden xl:flex flex-col gap-6 w-80 p-6 border-l-8 border-black/40 matte-plastic shadow-[inset_10px_0_20px_rgba(0,0,0,0.2)] overflow-y-auto">
    <!-- SERVICE HEADER -->
    <div class="flex flex-col gap-1 border-b-4 border-black/20 pb-4 shrink-0">
        <h2 class="text-[12px] font-pixel text-[#3a2a6b] italic opacity-80 uppercase tracking-tighter">
            Service Manual <span class="text-[8px] not-italic opacity-60">REF-89</span>
        </h2>
        <div class="h-1 bg-black/10 w-full"></div>
    </div>

    <!-- CONTROL SCHEME (Dymo Labels Style) -->
    <div class="space-y-6">
        <label class="text-[9px] font-pixel text-[#302080] opacity-70 uppercase">Operation Keys</label>
        
        <div class="grid grid-cols-1 gap-4">
            <!-- Key Tag: A -->
            <div class="flex items-center gap-4 group">
                <div class="w-10 h-6 bg-black/80 rounded-xs flex items-center justify-center border-b-2 border-white/10 shadow-lg">
                    <span class="text-[8px] font-pixel text-white">Z</span>
                </div>
                <span class="text-[7px] font-pixel text-zinc-600 uppercase tracking-widest group-hover:text-[#a01050] transition-colors">Action A / Shoot</span>
            </div>

            <!-- Key Tag: B -->
            <div class="flex items-center gap-4 group">
                <div class="w-10 h-6 bg-black/80 rounded-xs flex items-center justify-center border-b-2 border-white/10 shadow-lg">
                    <span class="text-[8px] font-pixel text-white">X</span>
                </div>
                <span class="text-[7px] font-pixel text-zinc-600 uppercase tracking-widest group-hover:text-[#a01050] transition-colors">Action B / Back</span>
            </div>

            <!-- Key Tag: Start -->
            <div class="flex items-center gap-4 group">
                <div class="w-14 h-6 bg-black/80 rounded-xs flex items-center justify-center border-b-2 border-white/10 shadow-lg">
                    <span class="text-[6px] font-pixel text-white uppercase">Enter</span>
                </div>
                <span class="text-[7px] font-pixel text-zinc-600 uppercase tracking-widest group-hover:text-[#a01050] transition-colors">Start / Menu</span>
            </div>

            <!-- Key Tag: Select -->
            <div class="flex items-center gap-4 group">
                <div class="w-14 h-6 bg-black/80 rounded-xs flex items-center justify-center border-b-2 border-white/10 shadow-lg">
                    <span class="text-[6px] font-pixel text-white uppercase">Shift</span>
                </div>
                <span class="text-[7px] font-pixel text-zinc-600 uppercase tracking-widest group-hover:text-[#a01050] transition-colors">Select / Palette</span>
            </div>
        </div>
    </div>

    <!-- HARDWARE DIAGNOSTICS -->
    <div class="space-y-4 pt-8 border-t-2 border-black/10">
        <label class="text-[9px] font-pixel text-[#302080] opacity-70 uppercase block">Diagnostics</label>
        
        <div class="p-3 bg-black/5 rounded border border-black/10 space-y-3">
             <div class="flex justify-between">
                <span class="text-[6px] font-pixel text-zinc-500">MEMORY MAP</span>
                <span class="text-[6px] font-pixel text-emerald-700 animate-pulse">OK</span>
             </div>
             <div class="w-full h-1.5 bg-black/20 rounded-full overflow-hidden">
                <div class="h-full bg-emerald-600 w-[65%] shadow-[0_0_5px_rgba(5,150,105,0.5)]"></div>
             </div>
             
             <div class="flex justify-between mt-4">
                <span class="text-[6px] font-pixel text-zinc-500">PRINT BUFFER</span>
                <span class="text-[6px] font-pixel text-zinc-400">IDLE</span>
             </div>
             <div class="flex gap-1 overflow-hidden">
                {[...Array(12)].map((_, i) => (
                    <div class="w-2 h-3 bg-black/10 border border-black/5" style={`opacity: ${0.2 + (i * 0.05)}`}></div>
                ))}
             </div>
        </div>
    </div>

    <!-- COPYRIGHT PLATE -->
    <div class="mt-auto p-4 bg-black/5 border border-black/10 rounded-sm">
        <p class="text-[5px] font-pixel leading-relaxed text-zinc-500 uppercase tracking-tighter">
            Game Boy Camera Studio<br>
            Engineering Dept.<br>
            Model: DMG-CAMERA-2026<br>
            Serial: #00042-89
        </p>
    </div>
</div>
