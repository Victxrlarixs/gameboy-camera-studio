---
import "../../styles/components/StudioSidePanel.css";
---
<div class="studio-panel hidden lg:flex flex-col gap-6 w-[340px] p-8 m-4 rounded-[12px_12px_80px_12px] h-[calc(100vh-40px)] overflow-y-auto overflow-x-hidden relative">



<div class="flex flex-col gap-1 border-b-2 border-black/10 pb-4 shrink-0">
        <h2 class="text-[13px] font-pixel text-[#302080] italic uppercase tracking-tighter embossed-text">
            Studio Processor
        </h2>
        <div class="flex gap-1.5 mt-1">
            <div class="w-1.5 h-1.5 rounded-full bg-[#a01050] shadow-md border border-black/20"></div>
            <div class="w-12 h-1 bg-[#302080]/30 rounded-full"></div>
            <div class="flex grow h-1 bg-black/5 rounded-full shadow-inner"></div>
        </div>
    </div>

<div class="space-y-8 shrink-0">
        
        <div class="space-y-3">
            <div class="flex justify-between items-end px-1">
                <label class="text-[8px] font-pixel text-[#3a2a6b] font-bold uppercase tracking-widest opacity-60">Brightness</label>
                <div class="flex gap-0.5" id="brightness-dots"></div>
            </div>
            <div class="relative h-10 debossed-panel flex items-center px-4 rounded-lg overflow-hidden border-t border-black/40">
                <input type="range" id="input-brightness" min="-1" max="1" step="0.1" value="0" class="dmg-slider relative z-20">
                <div class="absolute inset-x-4 h-1.5 bg-black/40 rounded-full shadow-inner z-10"></div>
            </div>
        </div>

<div class="space-y-3">
            <div class="flex justify-between items-end px-1">
                <label class="text-[8px] font-pixel text-[#3a2a6b] font-bold uppercase tracking-widest opacity-60">Contrast</label>
                <span id="val-contrast" class="text-[8px] font-pixel text-[#a01050] font-bold">1.0</span>
            </div>
            <div class="relative h-10 debossed-panel flex items-center px-4 rounded-lg overflow-hidden border-t border-black/40">
                <input type="range" id="input-contrast" min="0" max="2" step="0.1" value="1" class="dmg-slider relative z-20">
                <div class="absolute inset-x-4 h-1.5 bg-black/40 rounded-full shadow-inner z-10"></div>
            </div>
        </div>
    </div>

    <div class="space-y-4 shrink-0 pt-4">
        <label class="text-[8px] font-pixel text-[#302080]/50 uppercase tracking-[0.2em] mb-2 block">Photo Frames</label>
        <div id="frame-grid" class="flex gap-4 p-3 bg-black/5 rounded-xl border-2 border-black/5 shadow-inner overflow-x-auto custom-scrollbar-h">
            <!-- Frames will be populated here -->
        </div>
    </div>

<div class="space-y-4 shrink-0 pt-4">
        <label class="text-[8px] font-pixel text-[#302080]/50 uppercase tracking-[0.2em] mb-2 block">Film Stock</label>
        <div id="palette-grid" class="grid grid-cols-2 gap-4 p-3 bg-black/5 rounded-xl border-2 border-black/5 shadow-inner">
            
        </div>
    </div>

</div>


<script>
    import { StudioController } from "../../lib/studio-controller";
    new StudioController();
</script>
