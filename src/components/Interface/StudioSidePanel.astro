---
---
<div class="studio-panel hidden lg:flex flex-col gap-6 w-[320px] p-6 border-r-8 border-black/40 matte-plastic shadow-[inset_-10px_0_20px_rgba(0,0,0,0.2)] h-screen overflow-y-auto overflow-x-hidden">
    <!-- LABEL TOP (Industrial Engraved Style) -->
    <div class="flex flex-col gap-1 border-b-4 border-black/20 pb-4 shrink-0">
        <h2 class="text-[12px] font-pixel text-[#302080] italic opacity-80 uppercase tracking-tighter">
            Studio Controller <span class="text-[8px] not-italic opacity-60">GB-01</span>
        </h2>
        <div class="flex gap-1">
            <div class="w-full h-1 bg-[#a01050] opacity-40"></div>
            <div class="w-full h-1 bg-[#302080] opacity-40"></div>
        </div>
    </div>

    <!-- DEVELOPMENT SECTION -->
    <div class="space-y-6 shrink-0">
        <div class="flex items-center gap-2">
            <div class="w-2 h-6 bg-black/20"></div>
            <label class="text-[9px] font-pixel text-[#302080] opacity-70 uppercase">Image Processor</label>
        </div>

        <!-- BRIGHTNESS (DMG Style Slider Area) -->
        <div class="bg-black/5 p-4 rounded-sm border-2 border-black/10 shadow-inner space-y-4">
            <div class="flex justify-between items-center px-1">
                <span class="text-[8px] font-pixel text-[#1a1a1a]">BRIGHT</span>
                <div class="flex gap-1" id="brightness-dots">
                    <!-- Dots for status -->
                </div>
            </div>
            <div class="relative h-6 bg-black/10 rounded-full border-b-2 border-white/20 flex items-center px-2">
                <input type="range" id="input-brightness" min="-1" max="1" step="0.1" value="0" 
                    class="dmg-slider w-full appearance-none bg-transparent cursor-pointer z-10">
                <div class="absolute inset-x-4 h-1 bg-black/20 rounded-full"></div>
            </div>
        </div>

        <!-- CONTRAST -->
        <div class="bg-black/5 p-4 rounded-sm border-2 border-black/10 shadow-inner space-y-4">
            <div class="flex justify-between items-center px-1">
                <span class="text-[8px] font-pixel text-[#1a1a1a]">CONTRAST</span>
                <span id="val-contrast" class="text-[8px] font-pixel text-[#a01050]">1.0</span>
            </div>
            <div class="relative h-6 bg-black/10 rounded-full border-b-2 border-white/20 flex items-center px-2">
                <input type="range" id="input-contrast" min="0" max="2" step="0.1" value="1" 
                    class="dmg-slider w-full appearance-none bg-transparent cursor-pointer z-10">
                <div class="absolute inset-x-4 h-1 bg-black/20 rounded-full"></div>
            </div>
        </div>
    </div>

    <!-- PALETTE GRID (Cartridge Style Buttons) -->
    <div class="space-y-4 shrink-0">
        <label class="text-[9px] font-pixel text-[#302080] opacity-70 uppercase mb-4 block">Film Stock Selection</label>
        <div id="palette-grid" class="grid grid-cols-2 gap-3">
            <!-- Palettes will be injected here -->
        </div>
    </div>

    <!-- RECENT LAB (Negative Film Strip Style) -->
    <div class="mt-auto space-y-4 pt-6 border-t-4 border-black/10 shrink-0">
        <div class="flex justify-between items-center">
            <label class="text-[8px] font-pixel text-[#302080] opacity-50 uppercase">Lab Roll</label>
            <div class="flex gap-1">
                <div class="w-1.5 h-1.5 rounded-full bg-red-900 shadow-inner"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-red-900 shadow-inner"></div>
            </div>
        </div>
        <div id="recent-photos" class="flex gap-3 overflow-x-auto overflow-y-hidden p-3 bg-black/80 rounded border-2 border-black/40 shadow-2xl custom-scrollbar-h">
            <!-- Photos will look like film frames -->
            <div class="w-20 h-20 shrink-0 bg-[#0f380f]/20 border border-white/5 flex items-center justify-center relative">
                 <div class="w-full h-1 bg-white/5 absolute top-2"></div>
                 <span class="text-[5px] font-pixel text-white/20 uppercase">No Film</span>
                 <div class="w-full h-1 bg-white/5 absolute bottom-2"></div>
            </div>
        </div>
    </div>
</div>

<script>
    import { AppStore } from "../../store/app";
    import { PALETTES } from "../../lib/dither";

    const brightnessInput = document.getElementById('input-brightness') as HTMLInputElement;
    const contrastInput = document.getElementById('input-contrast') as HTMLInputElement;
    const contrastVal = document.getElementById('val-contrast');
    const paletteGrid = document.getElementById('palette-grid');
    const recentPhotos = document.getElementById('recent-photos');

    // Sync Sliders
    brightnessInput?.addEventListener('input', (e) => {
        AppStore.state.brightness = parseFloat((e.target as HTMLInputElement).value);
        window.dispatchEvent(new CustomEvent('gb-state-change'));
    });

    contrastInput?.addEventListener('input', (e) => {
        const val = parseFloat((e.target as HTMLInputElement).value);
        AppStore.state.contrast = val;
        if (contrastVal) contrastVal.innerText = val.toFixed(1);
        window.dispatchEvent(new CustomEvent('gb-state-change'));
    });

    // Populate Palette Grid
    if (paletteGrid) {
        Object.keys(PALETTES).forEach(name => {
            const btn = document.createElement('button');
            const colors = PALETTES[name];
            btn.className = `p-2 matte-plastic border-2 border-black/20 shadow-sm hover:translate-y-[-1px] active:translate-y-[1px] transition-all flex flex-col gap-2 items-center group rounded-sm ${AppStore.state.paletteName === name ? 'border-[#302080] bg-[#cfcecb]' : ''}`;
            
            const colorStrip = document.createElement('div');
            colorStrip.className = 'flex w-full h-4 rounded-xs overflow-hidden border border-black/40 shadow-inner';
            colors.forEach(c => {
                const dot = document.createElement('div');
                dot.style.backgroundColor = `rgb(${c.join(',')})`;
                dot.className = 'flex-1';
                colorStrip.appendChild(dot);
            });

            const label = document.createElement('span');
            label.className = 'text-[7px] font-pixel text-[#302080]/60 group-hover:text-[#302080]';
            label.innerText = name;

            btn.appendChild(colorStrip);
            btn.appendChild(label);
            
            btn.onclick = () => {
                AppStore.state.paletteName = name;
                AppStore.playSound('click');
                updatePaletteSelection();
                window.dispatchEvent(new CustomEvent('gb-state-change'));
            };
            paletteGrid.appendChild(btn);
        });
    }

    function updatePaletteSelection() {
        const buttons = paletteGrid?.querySelectorAll('button');
        buttons?.forEach((btn, idx) => {
            const name = Object.keys(PALETTES)[idx];
            if (AppStore.state.paletteName === name) {
                btn.classList.add('border-[#302080]', 'shadow-[inset_0_2px_4px_rgba(0,0,0,0.2)]');
                btn.classList.remove('border-black/20');
            } else {
                btn.classList.remove('border-[#302080]', 'shadow-[inset_0_2px_4px_rgba(0,0,0,0.2)]');
                btn.classList.add('border-black/20');
            }
        });
    }

    window.addEventListener('gb-print-start', (e: any) => {
        const { dataUrl } = e.detail;
        if (!recentPhotos) return;

        const frame = document.createElement('div');
        frame.className = 'w-24 h-24 shrink-0 bg-black p-1 border border-white/10 relative flex flex-col items-center justify-center group cursor-pointer hover:border-[#a01050] transition-all overflow-hidden';
        frame.innerHTML = `
            <div class="absolute top-1 inset-x-0 flex justify-around opacity-20"><div class="w-1 h-3 bg-white"></div><div class="w-1 h-3 bg-white"></div><div class="w-1 h-3 bg-white"></div></div>
            <img src="${dataUrl}" class="w-[85%] h-[85%] object-cover pixelated grayscale contrast-[1.4] shadow-2xl">
            <div class="absolute bottom-1 inset-x-0 flex justify-around opacity-20"><div class="w-1 h-3 bg-white"></div><div class="w-1 h-3 bg-white"></div><div class="w-1 h-3 bg-white"></div></div>
        `;
        
        frame.onclick = () => {
            const link = document.createElement('a');
            link.download = `negative-${Date.now()}.png`;
            link.href = dataUrl;
            link.click();
        };

        if (recentPhotos.children.length >= 6) {
            recentPhotos.removeChild(recentPhotos.lastChild!);
        }
        recentPhotos.prepend(frame);

        const empty = recentPhotos.querySelector('span');
        if (empty && empty.innerText === 'NO FILM') empty.parentElement?.remove();
    });

    window.addEventListener('gb-state-change', () => {
        if (brightnessInput) brightnessInput.value = AppStore.state.brightness.toString();
        if (contrastInput) contrastInput.value = AppStore.state.contrast.toString();
        if (contrastVal) contrastVal.innerText = AppStore.state.contrast.toFixed(1);
        updatePaletteSelection();
    });
</script>

<style>
    .dmg-slider {
        -webkit-appearance: none;
    }
    .dmg-slider::-webkit-slider-thumb {
        -webkit-appearance: none;
        height: 20px;
        width: 20px;
        border-radius: 4px;
        background: #6b6d70;
        border: 2px border-black;
        box-shadow: 1px 2px 0 rgba(0,0,0,0.4), inset 1px 1px 0 rgba(255,255,255,0.2);
        cursor: pointer;
    }

    .custom-scrollbar-h::-webkit-scrollbar {
        height: 6px;
    }
    .custom-scrollbar-h::-webkit-scrollbar-track {
        background: rgba(0,0,0,0.2);
        border-radius: 10px;
    }
    .custom-scrollbar-h::-webkit-scrollbar-thumb {
        background: #333;
        border-radius: 10px;
    }
</style>
