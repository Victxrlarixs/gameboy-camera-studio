---
import "../../styles/components/Controls.css";
---
<div class="controls-container flex flex-col gap-10 py-8 px-6 select-none w-full">
    
    <div class="flex justify-between items-start w-full px-2">
        
        <div class="relative w-36 h-36 flex items-center justify-center">
            <div class="absolute inset-0 bg-black/10 rounded-full shadow-[inset_4px_6px_12px_rgba(0,0,0,0.4),1px_1px_0_rgba(255,255,255,0.1)] border-b border-white/5"></div>
            <div class="dpad w-28 h-28">
                <div class="absolute w-10 h-28 bg-[#1a1a1a] rounded-sm shadow-[4px_6px_0_rgba(0,0,0,0.7),inset_0_2px_0_rgba(255,255,255,0.05)] border-b-2 border-r-2 border-black/40"></div>
                <div class="absolute w-28 h-10 bg-[#1a1a1a] rounded-sm shadow-[4px_6px_0_rgba(0,0,0,0.7),inset_0_2px_0_rgba(255,255,255,0.05)] border-b-2 border-r-2 border-black/40"></div>
                <div class="absolute w-10 h-10 rounded-full border-[3px] border-black/80 shadow-[inset_2px_3px_5px_rgba(0,0,0,0.8)] opacity-90"></div>
                
                <div class="absolute top-3 w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-b-[8px] border-b-black/60 opacity-80"></div>
                <div class="absolute bottom-3 w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-t-[8px] border-t-black/60 opacity-80"></div>
                <div class="absolute left-3 w-0 h-0 border-t-[6px] border-t-transparent border-b-[6px] border-b-transparent border-r-[8px] border-r-black/60 opacity-80"></div>
                <div class="absolute right-3 w-0 h-0 border-t-[6px] border-t-transparent border-b-[6px] border-b-transparent border-l-[8px] border-l-black/60 opacity-80"></div>
            </div>
            
            <div class="absolute inset-0 grid grid-cols-3 grid-rows-3 z-10">
                <div class="col-start-2"><button id="btn-up" class="w-full h-full active:brightness-90"></button></div>
                <div class="row-start-2 col-start-1"><button id="btn-left" class="w-full h-full active:brightness-90"></button></div>
                <div class="row-start-2 col-start-3"><button id="btn-right" class="w-full h-full active:brightness-90"></button></div>
                <div class="row-start-3 col-start-2"><button id="btn-down" class="w-full h-full active:brightness-90"></button></div>
            </div>
        </div>

<div class="flex gap-10 mt-12 rotate-[-25deg] translate-x-4">
            <div class="flex flex-col items-center">
                <div class="relative group">
                    <div class="absolute inset-x-[-8px] inset-y-[-8px] bg-black/25 rounded-full shadow-[inset_3px_4px_8px_rgba(0,0,0,0.6)]"></div>
                    <button id="btn-b" class="relative w-18 h-18 bg-[var(--gb-button-magenta)] rounded-full shadow-[inset_-2px_-2px_6px_rgba(0,0,0,0.6),0_8px_0_var(--gb-button-magenta-dark)] active:translate-y-2 transition-all">
                        <div class="absolute top-1 left-3 w-12 h-6 bg-white/10 rounded-full blur-[2px] opacity-60"></div>
                    </button>
                    <span class="absolute -bottom-12 left-1/2 -translate-x-1/2 text-[14px] font-pixel text-[#3a2a6b] opacity-60 font-bold tracking-widest">B</span>
                </div>
            </div>
            <div class="flex flex-col items-center">
                <div class="relative group">
                    <div class="absolute inset-x-[-8px] inset-y-[-8px] bg-black/25 rounded-full shadow-[inset_3px_4px_8px_rgba(0,0,0,0.6)]"></div>
                    <button id="btn-a" class="relative w-18 h-18 bg-[var(--gb-button-magenta)] rounded-full shadow-[inset_-2px_-2px_6px_rgba(0,0,0,0.6),0_8px_0_var(--gb-button-magenta-dark)] active:translate-y-2 transition-all">
                        <div class="absolute top-1 left-3 w-12 h-6 bg-white/10 rounded-full blur-[2px] opacity-60"></div>
                    </button>
                    <span class="absolute -bottom-12 left-1/2 -translate-x-1/2 text-[14px] font-pixel text-[#3a2a6b] opacity-60 font-bold tracking-widest">A</span>
                </div>
            </div>
        </div>
    </div>

<div class="flex justify-center gap-16 mt-16">
        <div class="flex flex-col items-center">
            <div class="relative w-20 h-6">
                <div class="absolute inset-x-[-2px] inset-y-[-2px] bg-black/20 rounded-full rotate-[-30deg] shadow-[inset_1px_2px_4px_rgba(0,0,0,0.6)]"></div>
                <button id="btn-select" class="absolute inset-0 bg-[#6b6d70] rounded-full rotate-[-30deg] shadow-[0_4px_0_#333] active:translate-y-[2px] transition-all"></button>
            </div>
            <span class="text-[10px] font-pixel text-[#302080] mt-10 uppercase opacity-60 tracking-[0.2em] font-bold">SELECT</span>
        </div>
        <div class="flex flex-col items-center">
            <div class="relative w-20 h-6">
                <div class="absolute inset-x-[-2px] inset-y-[-2px] bg-black/20 rounded-full rotate-[-30deg] shadow-[inset_1px_2px_4px_rgba(0,0,0,0.6)]"></div>
                <button id="btn-start" class="absolute inset-0 bg-[#6b6d70] rounded-full rotate-[-30deg] shadow-[0_4px_0_#333] active:translate-y-[2px] transition-all"></button>
            </div>
            <span class="text-[10px] font-pixel text-[#302080] mt-10 uppercase opacity-60 tracking-[0.2em] font-bold">START</span>
        </div>
    </div>
</div>

<script>
    import { ControlsController } from "../../lib/controls-controller";
    new ControlsController();
</script>
