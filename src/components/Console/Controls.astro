---

---

<div
    class="controls-container flex flex-col gap-10 py-8 px-6 select-none w-full"
>
    <!-- D-Pad & Action Buttons -->
    <div class="flex justify-between items-start w-full px-2">
        <!-- Directional Pad (Deep Circular Well) -->
        <div class="relative w-36 h-36 flex items-center justify-center">
            <!-- The Recessed Circular Well (Authentic DMG) -->
            <div
                class="absolute inset-0 bg-black/15 rounded-full shadow-[inset_6px_8px_12px_rgba(0,0,0,0.5),2px_2px_0_rgba(255,255,255,0.1)] border-b border-white/5"
            >
            </div>

            <div
                class="dpad relative w-28 h-28 flex items-center justify-center"
            >
                <!-- Vertical Bar -->
                <div
                    class="absolute w-10 h-28 bg-[#1a1a1a] rounded-sm shadow-[4px_8px_0_rgba(0,0,0,0.5),inset_0_2px_0_rgba(255,255,255,0.05)] border-b-2 border-r-2 border-black/40"
                >
                </div>
                <!-- Horizontal Bar -->
                <div
                    class="absolute w-28 h-10 bg-[#1a1a1a] rounded-sm shadow-[4px_8px_0_rgba(0,0,0,0.5),inset_0_2px_0_rgba(255,255,255,0.05)] border-b-2 border-r-2 border-black/40"
                >
                </div>

                <!-- Center textured thumb circle -->
                <div
                    class="absolute w-10 h-10 rounded-full bg-[#151515] shadow-[inset_0_0_12px_rgba(0,0,0,0.6)] opacity-40"
                >
                </div>

                <!-- Tactile Indicators -->
                <div
                    class="absolute top-2.5 w-5 h-1 bg-black opacity-30 rounded-full"
                >
                </div>
                <div
                    class="absolute bottom-2.5 w-5 h-1 bg-black opacity-30 rounded-full"
                >
                </div>
                <div
                    class="absolute left-2.5 w-1 h-5 bg-black opacity-30 rounded-full"
                >
                </div>
                <div
                    class="absolute right-2.5 w-1 h-5 bg-black opacity-30 rounded-full"
                >
                </div>

                <!-- Invisible Inputs -->
                <button
                    id="btn-up"
                    class="absolute top-0 w-12 h-12 z-10 active:brightness-90"
                ></button>
                <button
                    id="btn-down"
                    class="absolute bottom-0 w-12 h-12 z-10 active:brightness-90"
                ></button>
                <button
                    id="btn-left"
                    class="absolute left-0 w-12 h-12 z-10 active:brightness-90"
                ></button>
                <button
                    id="btn-right"
                    class="absolute right-0 w-12 h-12 z-10 active:brightness-90"
                ></button>
            </div>
        </div>

        <!-- Maroon Action Buttons (A/B) -->
        <div class="flex gap-8 mt-12 rotate-[-20deg] translate-x-4">
            <!-- B Button -->
            <div class="flex flex-col items-center">
                <div class="relative group">
                    <div
                        class="absolute inset-x-[-15px] inset-y-[-15px] bg-black/5 rounded-full blur-2xl translate-y-6"
                    >
                    </div>
                    <button
                        id="btn-b"
                        class="relative w-16 h-16 bg-[#a01050] rounded-full shadow-[inset_-4px_-4px_8px_rgba(0,0,0,0.4),inset_4px_4px_8px_rgba(255,255,255,0.1),0_8px_0_#500828,10px_15px_25px_rgba(0,0,0,0.5)] active:translate-y-2 active:shadow-[inset_-2px_-2px_4px_rgba(0,0,0,0.4),0_2px_0_#500828] transition-all flex items-center justify-center"
                    >
                        <span
                            class="absolute -bottom-10 text-[12px] font-pixel text-[#302080] opacity-80 uppercase font-bold tracking-widest drop-shadow-sm"
                            >B</span
                        >
                    </button>
                </div>
            </div>
            <!-- A Button -->
            <div class="flex flex-col items-center">
                <div class="relative group">
                    <div
                        class="absolute inset-x-[-15px] inset-y-[-15px] bg-black/5 rounded-full blur-2xl translate-y-6"
                    >
                    </div>
                    <button
                        id="btn-a"
                        class="relative w-16 h-16 bg-[#a01050] rounded-full shadow-[inset_-4px_-4px_8px_rgba(0,0,0,0.4),inset_4px_4px_8px_rgba(255,255,255,0.1),0_8px_0_#500828,10px_15px_25px_rgba(0,0,0,0.5)] active:translate-y-2 active:shadow-[inset_-2px_-2px_4px_rgba(0,0,0,0.4),0_2px_0_#500828] transition-all flex items-center justify-center"
                    >
                        <span
                            class="absolute -bottom-10 text-[12px] font-pixel text-[#302080] opacity-80 uppercase font-bold tracking-widest drop-shadow-sm"
                            >A</span
                        >
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Start/Select (Rubber Style) -->
    <div class="flex justify-center gap-14 mt-12">
        <div class="flex flex-col items-center group">
            <div class="relative w-18 h-5">
                <div
                    class="absolute inset-0 bg-black/20 rounded-full rotate-[-30deg] blur-[2px] translate-y-1.5 translate-x-1"
                >
                </div>
                <button
                    id="btn-select"
                    class="absolute inset-0 bg-[#6b6d70] rounded-full rotate-[-30deg] shadow-[inset_1px_1px_2px_rgba(255,255,255,0.2),inset_-2px_-2px_4px_rgba(0,0,0,0.4),0_3px_0_#444] active:translate-y-[2px] active:shadow-none transition-all"
                ></button>
            </div>
            <span
                class="text-[10px] font-pixel text-[#302080] mt-8 uppercase opacity-60 tracking-[0.2em] font-bold"
                >SELECT</span
            >
        </div>

        <div class="flex flex-col items-center group">
            <div class="relative w-18 h-5">
                <div
                    class="absolute inset-0 bg-black/20 rounded-full rotate-[-30deg] blur-[2px] translate-y-1.5 translate-x-1"
                >
                </div>
                <button
                    id="btn-start"
                    class="absolute inset-0 bg-[#6b6d70] rounded-full rotate-[-30deg] shadow-[inset_1px_1px_2px_rgba(255,255,255,0.2),inset_-2px_-2px_4px_rgba(0,0,0,0.4),0_3px_0_#444] active:translate-y-[2px] active:shadow-none transition-all"
                ></button>
            </div>
            <span
                class="text-[10px] font-pixel text-[#302080] mt-8 uppercase opacity-60 tracking-[0.2em] font-bold"
                >START</span
            >
        </div>
    </div>
</div>

<style>
    button {
        outline: none;
        -webkit-tap-highlight-color: transparent;
        cursor: pointer;
    }
</style>
