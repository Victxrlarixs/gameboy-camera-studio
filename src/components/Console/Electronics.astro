---
import "../../styles/components/Electronics.css";
---
<div class="electronics-layer absolute inset-[12px] sm:inset-[16px] rounded-[12px_12px_210px_12px] overflow-hidden pointer-events-none z-0 opacity-0 transition-opacity duration-1000">
    <!-- Main PCB Board (High-Fidelity FR-4 Substrate) -->
    <div class="pcb-board absolute inset-0 bg-[#356335] shadow-[inset_0_0_120px_rgba(0,0,0,0.8)] border border-white/5 isolate">
        
        <!-- Underlying Phenolic Depth (The orange-brown internal layers) -->
        <div class="absolute left-0 top-[30%] w-4 h-[40%] bg-[#b87333]/20 blur-md"></div>
        <div class="absolute right-0 top-[60%] w-4 h-[15%] bg-[#b87333]/20 blur-md"></div>

        <!-- High-Density PCB Pattern & Copper Traces -->
        <div class="absolute inset-0 opacity-[0.4] pcb-pattern"></div>
        <div class="absolute inset-x-0 top-0 bottom-0 opacity-[0.1] pcb-grid"></div>

        <!-- Master Circuitry (SVG Layer) -->
        <svg class="absolute inset-0 w-full h-full opacity-[0.7]" viewBox="0 0 500 850" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <filter id="trace-glow-master" x="-20%" y="-20%" width="140%" height="140%">
                    <feGaussianBlur stdDeviation="0.4" result="blur"/>
                    <feComposite in="SourceGraphic" in2="blur" operator="over"/>
                </filter>
            </defs>
            <g stroke="#a3c46a" fill="none" stroke-width="1.2" filter="url(#trace-glow-master)">
                <!-- Data Bus Paths -->
                {[...Array(14)].map((_, i) => (
                    <path d={`M${140 + i*4} 0 V150 Q${140 + i*4} 170 ${160 + i*4} 190`} opacity={0.2 + (i%2)*0.4} />
                ))}
                <!-- Power Rails -->
                <path d="M60 0 V850" stroke-width="3" opacity="0.3" stroke="#2d5a2d" />
                <path d="M440 0 V850" stroke-width="3" opacity="0.3" stroke="#2d5a2d" />
            </g>
            
            <!-- Real Solder Joints (Silver/Gold) -->
            <g fill="#cbd5e1" opacity="0.9">
                {[...Array(120)].map(() => (
                    <circle cx={Math.random()*500} cy={Math.random()*850} r={Math.random()*2 + 1} />
                ))}
            </g>
        </svg>

        <!-- Dynamic Components Layer -->
        <div class="absolute inset-0 z-10">
            
            <!-- LCD Ribbon Flex Cable (The orange "flex" the user requested) -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[200px] h-[55px] bg-[#a0522d] shadow-2xl flex flex-col justify-evenly py-2 border-x-4 border-black/30 z-30 overflow-hidden group-data-[skin=TRANSPARENT]:animate-pulse-slow">
                <div class="absolute inset-0 bg-gradient-to-r from-black/20 via-white/10 to-black/20"></div>
                <!-- Flex Traces -->
                {[...Array(24)].map(() => (
                    <div class="h-[0.5px] w-full bg-[#111]/40"></div>
                ))}
                <!-- Flex Serial Labels -->
                <div class="absolute bottom-1 right-2 text-[3px] font-mono text-black/60 uppercase">DMG-LCD-FPC-01</div>
            </div>

            <!-- EMI Metallic Shield (From the Play It Loud edition) -->
            <div class="absolute top-[170px] left-1/2 -translate-x-1/2 w-[65%] h-[110px] bg-zinc-400 shadow-[inset_0_2px_10px_rgba(255,255,255,0.6),0_15px_30px_rgba(0,0,0,0.7)] rounded-[2px] border-t border-white/50 z-20 overflow-hidden perspective-1000">
                <div class="absolute inset-0 bg-gradient-to-br from-white/20 via-transparent to-black/20"></div>
                <!-- Shield Texture -->
                <div class="absolute inset-0 opacity-10 bg-[url('data:image/svg+xml,%3Csvg viewBox=%220 0 100 100%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Crect width=%22100%22 height=%22100%22 fill=%22black%22/%3E%3C/svg%3E')]"></div>
                <!-- Rivets -->
                <div class="absolute top-3 left-4 w-3 h-3 rounded-full bg-zinc-500 border border-black/30 shadow-inner"></div>
                <div class="absolute top-3 right-4 w-3 h-3 rounded-full bg-zinc-500 border border-black/30 shadow-inner"></div>
                <div class="absolute bottom-3 left-10 w-2.5 h-2.5 rounded-full bg-zinc-600 border border-black/30 shadow-inner"></div>
                <div class="absolute bottom-3 right-10 w-2.5 h-2.5 rounded-full bg-zinc-600 border border-black/30 shadow-inner"></div>
                <!-- Nintendo Mark -->
                <div class="absolute inset-0 flex items-center justify-center opacity-10">
                    <span class="text-[10px] font-bold tracking-widest text-zinc-900 border-2 border-zinc-900 px-2 py-0.5 rounded-md">Nintendo</span>
                </div>
            </div>

            <!-- Internal Component Details -->
            <!-- CPU (Behind Shield - hinted shadow) -->
            <div class="absolute top-[80px] left-1/2 -translate-x-1/2 w-32 h-32 bg-[#080808] rounded-sm border border-zinc-800 shadow-[0_10px_40px_rgba(0,0,0,0.9)] flex items-center justify-center opacity-90">
                <!-- Silver Pins -->
                <div class="absolute -left-3 inset-y-4 flex flex-col justify-between">
                    {[...Array(8)].map(() => <div class="w-4 h-[2px] bg-zinc-500 shadow-sm"></div>)}
                </div>
                <div class="absolute -right-3 inset-y-4 flex flex-col justify-between">
                    {[...Array(8)].map(() => <div class="w-4 h-[2px] bg-zinc-500 shadow-sm"></div>)}
                </div>
                <div class="text-[6px] text-zinc-400 font-bold tracking-widest text-center">LR35902<br/><span class="text-[4px] opacity-40">U1 PROCESSOR</span></div>
            </div>

            <!-- Discrete Components Density -->
            <div class="absolute inset-x-10 top-[280px] flex flex-wrap gap-3 opacity-60">
                 {[...Array(20)].map(() => <div class="w-2.5 h-1 bg-amber-900/80 rounded-sm shadow-sm"></div>)}
                 {[...Array(15)].map(() => <div class="w-2 h-1 bg-zinc-700 rounded-sm shadow-sm"></div>)}
            </div>

            <!-- Electrolytic Capacitor Farm -->
            <div class="absolute top-[320px] left-[40px] flex flex-col gap-4">
                 <div class="capacitor-cyl black-cap w-10 h-20 shadow-2xl"><div class="cap-label text-[4px]">100µF</div></div>
                 <div class="capacitor-cyl blue-cap w-7 h-14 rotate-[15deg] shadow-xl"><div class="cap-label text-[4px]">47µF</div></div>
            </div>
            <div class="absolute top-[300px] right-[40px] flex flex-col gap-4">
                 <div class="capacitor-cyl blue-cap w-8 h-18 -rotate-[10deg] shadow-xl"><div class="cap-label text-[4px]">68µF</div></div>
                 <div class="capacitor-cyl black-cap w-6 h-12 shadow-md"><div class="cap-label text-[4px]">22µF</div></div>
            </div>

            <!-- White Button Mounts (Semi-Transparent) -->
            <div class="absolute bottom-[200px] left-[65px] w-[130px] h-[130px] rounded-full bg-[#fdfdf8]/60 shadow-xl border border-white/10 flex items-center justify-center backdrop-blur-[0.5px]">
                <div class="w-16 h-16 bg-black/60 rounded-full border border-white/5"></div>
            </div>
            <div class="absolute bottom-[230px] right-[50px] rotate-[-15deg] flex gap-10">
                <div class="w-20 h-20 rounded-full bg-[#fdfdf8]/50 shadow-lg border border-white/10 flex items-center justify-center backdrop-blur-[0.5px]">
                    <div class="w-12 h-12 bg-black/60 rounded-full"></div>
                </div>
                <div class="w-20 h-20 rounded-full bg-[#fdfdf8]/50 shadow-lg border border-white/10 flex items-center justify-center backdrop-blur-[0.5px]">
                    <div class="w-12 h-12 bg-black/60 rounded-full"></div>
                </div>
            </div>

            <!-- Audio & Power Sub-PCB -->
            <div class="absolute bottom-[10px] left-1/2 -translate-x-1/2 w-[75%] h-[75px] bg-[#2d502d] rounded-sm shadow-2xl border-t border-white/20 isolate overflow-hidden">
                 <div class="absolute inset-0 opacity-20 pcb-pattern scale-50"></div>
                 <!-- Headphone Jack Module -->
                 <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-28 h-14 bg-zinc-950 rounded-t-sm border border-white/5 flex items-center justify-center shadow-inner">
                    <div class="w-[85%] h-5 bg-black rounded-full border border-white/5"></div>
                 </div>
            </div>

            <!-- Speaker (The ultimate version) -->
            <div class="absolute bottom-[40px] right-[20px] w-[180px] h-[180px] flex items-center justify-center z-20">
                <div class="w-[150px] h-[150px] rounded-full bg-[#050505] shadow-[inset_0_0_60px_black,0_20px_40px_rgba(0,0,0,0.9)] flex items-center justify-center overflow-hidden rotate-[45deg] isolate border-[6px] border-[#111]">
                    <!-- Copper wire coil winding (Mechanical look) -->
                    <div class="absolute inset-[8%] rounded-full border-[12px] border-[#8b4513]/30 bg-[repeating-radial-gradient(circle,#b87333_0px,#b87333_1.5px,transparent_2px,transparent_4px)]"></div>
                    <!-- Transparent Mylar Cone -->
                    <div class="w-full h-full rounded-full bg-[radial-gradient(circle,rgba(255,255,255,0.04)_0%,transparent_70%)] relative flex items-center justify-center">
                        <div class="w-1/2 h-1/2 rounded-full bg-gradient-to-tr from-zinc-950 via-zinc-800 to-zinc-900 border-4 border-zinc-700 shadow-2xl flex items-center justify-center">
                            <div class="w-[60%] h-[60%] rounded-full bg-zinc-900 border-2 border-zinc-600 shadow-inner"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Silk-Screen Labels (Faint but highly detailed) -->
            <div class="absolute top-[35px] right-[40px] opacity-[0.05] select-none text-right">
                <div class="text-[14px] font-pixel text-white font-bold tracking-thicker">DMG-MAIN-04</div>
                <div class="text-[6px] font-pixel text-white">2026.03.14-MASTER-REV</div>
            </div>

        </div>
    </div>
</div>


