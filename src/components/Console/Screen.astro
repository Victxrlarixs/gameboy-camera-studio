---

---

<div class="w-full h-full relative cursor-crosshair overflow-hidden">
    <canvas
        id="gb-canvas"
        width="160"
        height="144"
        class="w-full h-full block image-pixelated"></canvas>

    <div
        id="ui-overlay"
        class="absolute inset-0 pointer-events-none p-4 flex flex-col justify-between hidden"
    >
        <div class="flex justify-between items-start">
            <div
                id="ui-top-left"
                class="text-[10px] font-pixel text-[#0f380f] bg-[#9bbc0f]/60 px-2 py-0.5 rounded-sm"
            >
            </div>
            <div
                id="ui-top-right"
                class="text-[10px] font-pixel text-[#0f380f] bg-[#9bbc0f]/60 px-2 py-0.5 rounded-sm"
            >
            </div>
        </div>
        <div class="flex justify-between items-end">
            <div
                id="ui-bottom-left"
                class="text-[10px] font-pixel text-[#0f380f] bg-[#9bbc0f]/60 px-2 py-0.5 rounded-sm"
            >
            </div>
            <div
                id="ui-bottom-right"
                class="text-[10px] font-pixel text-[#0f380f] bg-[#9bbc0f]/60 px-2 py-0.5 rounded-sm"
            >
            </div>
        </div>
    </div>

    <div class="absolute inset-0 pointer-events-none scanlines"></div>
    <div
        class="absolute inset-0 pointer-events-none crt-flicker opacity-10 bg-white"
    >
    </div>
    <div
        class="absolute inset-0 pointer-events-none shadow-[inset_0_0_20px_rgba(0,0,0,0.3)]"
    >
    </div>
</div>

<script>
    import { AppStore } from "../../store/app";
    import { CameraEngine } from "../../features/camera/CameraEngine";
    import { PhotoStore } from "../../store/photos";

    const canvas = document.getElementById("gb-canvas") as HTMLCanvasElement;
    const ctx = canvas.getContext("2d", { alpha: false });
    const uiOverlay = document.getElementById("ui-overlay");

    let camera: CameraEngine | null = null;
    let lastSavedPhoto: any = null;
    let splashStep = 0;
    let splashTime = 0;

    if (ctx) {
        ctx.imageSmoothingEnabled = false;
        mainLoop();

        // Auto-start camera permission request after splash sequence
        setTimeout(() => {
            checkCameraPermission();
        }, 4000); // Wait for splash to finish roughly
    }

    async function checkCameraPermission() {
        try {
            const stream = await navigator.mediaDevices.getUserMedia({
                video: true,
            });
            stream.getTracks().forEach((t) => t.stop()); // Just checking
            AppStore.setMode("SHOOT");
        } catch (e) {
            console.warn("Waiting for camera permission...");
        }
    }

    window.addEventListener("gb-state-change", () => {
        if (AppStore.state.mode === "SHOOT") {
            updateShootUI();
        }
    });

    function mainLoop() {
        if (!ctx) return;

        switch (AppStore.state.mode) {
            case "SPLASH":
                renderSplash();
                break;
            case "SHOOT":
                updateShootUI();
                break;
            case "VIEW":
                renderGallery();
                break;
        }

        if (AppStore.state.mode !== "SHOOT") {
            requestAnimationFrame(mainLoop);
        }
    }

    function renderSplash() {
        if (!ctx) return;
        ctx.fillStyle = "#9bbc0f";
        ctx.fillRect(0, 0, 160, 144);

        ctx.font = '12px "Press Start 2P"';
        ctx.fillStyle = "#0f380f";
        ctx.textAlign = "center";

        // Classic Nintendo logo drop animation simulation
        const y = Math.min(60, splashStep * 2);
        ctx.fillText("Nintendo", 80, y);

        if (splashStep > 30) {
            ctx.font = '8px "Press Start 2P"';
            ctx.fillText("Game Boy", 80, 80);
        }

        if (splashStep > 60) {
            ctx.font = '6px "Press Start 2P"';
            ctx.fillText("CAMERA STUDIO", 80, 100);
        }

        splashStep++;

        // Auto-advance if permission already exists or after long time
        if (splashStep > 150 && AppStore.state.mode === "SPLASH") {
            AppStore.setMode("SHOOT");
        }

        uiOverlay?.classList.add("hidden");
    }

    function updateShootUI() {
        const tl = document.getElementById("ui-top-left");
        const tr = document.getElementById("ui-top-right");
        const bl = document.getElementById("ui-bottom-left");
        const br = document.getElementById("ui-bottom-right");

        if (tl)
            tl.innerText = `BRIGHT:${(AppStore.state.brightness * 10).toFixed(0)}`;
        if (tr) tr.innerText = `${AppStore.state.paletteName} (SEL)`;
        if (bl) bl.innerText = "SEL: PALETTE";

        if (br) {
            if (lastSavedPhoto) {
                br.innerText = "START: SAVE";
            } else {
                br.innerText = "A: SHOOT";
            }
        }

        uiOverlay?.classList.remove("hidden");
    }

    function renderGallery() {
        // Basic gallery if ever needed, but we stay in SHOOT mostly
    }

    function startCamera() {
        if (!canvas) return;
        if (!camera) camera = new CameraEngine(canvas);
        camera.start();
    }

    function stopCamera() {
        if (camera) {
            camera.stop();
            camera = null;
        }
    }

    window.addEventListener("gb-mode-change", (e: any) => {
        const { mode } = e.detail;
        if (mode === "SHOOT") {
            startCamera();
        } else {
            stopCamera();
            mainLoop();
        }
    });

    window.addEventListener("gb-input", (e: any) => {
        const { button } = e.detail;

        if (AppStore.state.mode === "SHOOT" && camera) {
            if (button === "a") {
                lastSavedPhoto = camera.takePhoto();
                AppStore.playSound("shutter");
                flashScreen();
                // AUTO DISPATCH TO PRINTER
                window.dispatchEvent(
                    new CustomEvent("gb-print-start", {
                        detail: { dataUrl: lastSavedPhoto.dataUrl },
                    }),
                );
                updateShootUI();
            }

            if (button === "start" && lastSavedPhoto) {
                const link = document.createElement("a");
                link.download = `gb-cam-${Date.now()}.png`;
                link.href = lastSavedPhoto.dataUrl;
                link.click();
                lastSavedPhoto = null;
                updateShootUI();
            }
        }
    });

    function flashScreen() {
        if (!ctx) return;
        const overlay = document.createElement("div");
        overlay.className =
            "absolute inset-0 bg-white z-[100] transition-opacity";
        canvas.parentElement?.appendChild(overlay);
        setTimeout(() => {
            overlay.style.opacity = "0";
            setTimeout(() => overlay.remove(), 200);
        }, 50);
    }

    [
        "btn-up",
        "btn-down",
        "btn-left",
        "btn-right",
        "btn-a",
        "btn-b",
        "btn-select",
        "btn-start",
    ].forEach((id) => {
        document
            .getElementById(id)
            ?.addEventListener("mousedown", () =>
                AppStore.handleInput(id.replace("btn-", "")),
            );
    });

    const keyMap: Record<string, string> = {
        ArrowUp: "up",
        ArrowDown: "down",
        ArrowLeft: "left",
        ArrowRight: "right",
        z: "a",
        x: "b",
        Enter: "start",
        Shift: "select",
    };

    window.addEventListener("keydown", (e) => {
        if (keyMap[e.key]) {
            AppStore.handleInput(keyMap[e.key]);
            document
                .getElementById(`btn-${keyMap[e.key]}`)
                ?.classList.add("translate-y-[2px]", "brightness-75");
        }
    });

    window.addEventListener("keyup", (e) => {
        if (keyMap[e.key]) {
            document
                .getElementById(`btn-${keyMap[e.key]}`)
                ?.classList.remove("translate-y-[2px]", "brightness-75");
        }
    });
</script>
