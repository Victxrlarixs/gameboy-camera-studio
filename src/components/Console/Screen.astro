<div class="w-full h-full relative cursor-crosshair overflow-hidden">
    <canvas
        id="gb-canvas"
        width="160"
        height="144"
        class="w-full h-full block image-pixelated lcd-ghosting"></canvas>

    <div
        id="ui-overlay"
        class="absolute inset-0 pointer-events-none p-4 flex flex-col justify-between hidden"
    >
        <div class="flex justify-between items-start">
            <div id="ui-top-left" class="text-[10px] font-pixel text-[#0f380f] bg-[#9bbc0f]/60 px-2 py-0.5 rounded-sm"></div>
            <div id="ui-top-right" class="text-[10px] font-pixel text-[#0f380f] bg-[#9bbc0f]/60 px-2 py-0.5 rounded-sm"></div>
        </div>
        <div class="flex justify-between items-end">
            <div id="ui-bottom-left" class="text-[10px] font-pixel text-[#0f380f] bg-[#9bbc0f]/60 px-2 py-0.5 rounded-sm"></div>
            <div id="ui-bottom-right" class="text-[10px] font-pixel text-[#0f380f] bg-[#9bbc0f]/60 px-2 py-0.5 rounded-sm"></div>
        </div>
    </div>

    <div class="absolute inset-0 pointer-events-none scanlines"></div>
    <div class="absolute inset-0 pointer-events-none crt-flicker opacity-10 bg-white"></div>
    <div class="absolute inset-0 pointer-events-none shadow-[inset_0_0_20px_rgba(0,0,0,0.3)]"></div>
</div>

<script>
    import { DisplaySystem } from "../../lib/display-system";
    new DisplaySystem("gb-canvas", "ui-overlay");
</script>
