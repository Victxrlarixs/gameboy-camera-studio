---

<div
    id="gb-cartridge"
    class="relative w-[340px] sm:w-[360px] h-64 z-0 flex flex-col items-center mb-[-100px]"
>

    <!-- Top Header for Camera Eye (Solid Connection) -->
    <div class="h-[100px] w-full flex justify-center items-end relative z-10">
        <!-- The Eye Sphere (Proportional and Solid) -->
        <div class="w-52 h-52 flex flex-col items-center">
            <div class="relative w-44 h-44 rounded-full bg-[#1a1b1c] charcoal-plastic border-[4px] border-black shadow-[15px_20px_40px_rgba(0,0,0,0.8),inset_-10px_-10px_30px_rgba(0,0,0,0.8)] overflow-hidden flex items-center justify-center">
                <!-- White Lens Face (Inner) -->
                <div class="w-32 h-32 bg-[#eeeeee] rounded-full border-[3px] border-black/50 shadow-[inset_2px_2px_8px_rgba(0,0,0,0.4)] flex items-center justify-center relative overflow-hidden">
                    <!-- Metal Ring Highlight -->
                    <div class="absolute inset-0 border-[6px] border-black/15 rounded-full pointer-events-none"></div>
                    
                    <!-- Lens Glass -->
                    <div class="relative w-22 h-22 bg-[#050505] rounded-full border-[5px] border-black shadow-[inset_0_0_20px_black] flex items-center justify-center">
                        <!-- Reflection -->
                        <div class="absolute top-4 left-4 w-12 h-8 bg-white/10 rounded-full blur-[4px] rotate-[-25deg]"></div>
                        <div class="absolute top-3 left-4 w-4 h-4 bg-white/30 rounded-full blur-[1px]"></div>
                        
                        <!-- Inner Sensor Circle -->
                        <div class="w-14 h-14 bg-black rounded-full border border-zinc-900 shadow-[inset_0_0_5px_rgba(0,255,255,0.05)]"></div>
                    </div>
                </div>
            </div>
            
            <!-- Swivel Base Neck (Grounded Connection) -->
            <div class="absolute bottom-[20px] w-50 h-16 bg-[#141516] rounded-t-[50%] shadow-md border-b border-black/40 z-[-1] charcoal-plastic"></div>
        </div>
    </div>

    <!-- Cartridge Body (FRONT LABEL FOCUS) -->
    <div
        class="charcoal-plastic relative w-full h-44 rounded-t-lg shadow-[20px_30px_60px_rgba(0,0,0,0.8),inset_2px_2px_0_rgba(255,255,255,0.05)] border-x-[12px] border-black/70 flex flex-col items-center"
    >

        <!-- THE CHARACTERISTIC LABEL (High Gloss Sticker) -->
        <div
            class="absolute top-10 left-4 right-4 h-26 bg-black/60 rounded-sm p-1.5 shadow-[inset_4px_4px_10px_black]"
        >
            <div
                class="w-full h-full bg-[#cc0000] shadow-xl flex flex-col items-start justify-center px-4 relative overflow-hidden rounded-xs border-b border-black/30"
            >
                <div
                    class="text-[6px] font-pixel text-white/50 mb-1 uppercase tracking-[0.2em] font-bold"
                >
                    STUDIO
                </div>
                <div
                    class="text-[22px] font-pixel text-white font-bold tracking-tighter italic uppercase leading-none drop-shadow-[2px_3px_2px_rgba(0,0,0,0.8)]"
                >
                    camera
                </div>

                <!-- High-Gloss Shine Overlay -->
                <div
                    class="absolute inset-0 bg-gradient-to-br from-white/30 via-transparent to-black/40 pointer-events-none"
                >
                </div>
                <div class="absolute top-0 right-0 w-32 h-64 bg-white/5 rotate-[45deg] translate-x-10 -translate-y-20 pointer-events-none"></div>
            </div>
        </div>

        <!-- Sloped Integrated Shoulders -->
        <div
            class="absolute -top-7 left-[-4px] w-20 h-10 bg-[#2a2b2e] border-l-[8px] border-black/70 -skew-x-[20deg] rounded-tl-xl shadow-lg charcoal-plastic"
        >
        </div>
        <div
            class="absolute -top-7 right-[-4px] w-20 h-10 bg-[#2a2b2e] border-r-[8px] border-black/70 skew-x-[20deg] rounded-tr-xl shadow-lg charcoal-plastic"
        >
        </div>

        <!-- Friction Strips -->
        <div
            class="absolute bottom-4 left-8 right-8 flex flex-col gap-3 opacity-30"
        >
            <div class="w-full h-[2px] bg-white/20 shadow-inner"></div>
            <div class="w-full h-[2px] bg-white/20 shadow-inner"></div>
        </div>
    </div>
</div>
