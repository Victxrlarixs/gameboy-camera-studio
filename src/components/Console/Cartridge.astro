---
import "../../styles/components/Cartridge.css";
---

<div
    id="gb-cartridge"
    class="relative w-[340px] sm:w-[360px] h-[320px] z-0 flex flex-col items-center mb-[-120px] transition-transform duration-500 ease-in-out"
>
    <!-- Sphere (The Eye) -->
    <div class="h-[180px] w-full flex justify-center items-end relative z-30">
        
        <button 
            id="camera-eye-toggle"
            class="relative w-48 h-48 flex flex-col items-center justify-center cursor-pointer group active:scale-95 transition-transform duration-200 outline-none"
            aria-label="Toggle Camera"
        >
            <!-- Sphere Body -->
            <div id="camera-sphere" class="relative w-[182px] h-[182px] rounded-full bg-[#1e1f21] border-t border-white/10 shadow-[20px_40px_70px_rgba(0,0,0,0.8),inset_-12px_-18px_40px_rgba(0,0,0,0.7),inset_10px_12px_25px_rgba(255,255,255,0.12)] flex items-center justify-center transition-transform duration-700 ease-in-out">
                <div class="absolute inset-0 rounded-full pointer-events-none plastic-grain opacity-40 mix-blend-overlay"></div>
                
                <!-- FRONT FACE: Lens -->
                <div class="absolute inset-0 flex items-center justify-center overflow-hidden rounded-full backface-hidden">
                    <!-- Inner Rotating Ring (DMG Light Gray) -->
                    <div class="w-[120px] h-[120px] bg-[#d1d2d4] rounded-full border-[1.5px] border-black/30 shadow-[inset_6px_10px_20px_rgba(0,0,0,0.8),inset_-4px_-4px_10px_rgba(255,255,255,0.7),0_2px_4px_rgba(0,0,0,0.8)] flex items-center justify-center relative overflow-hidden z-10">
                        <div class="absolute inset-0 plastic-grain opacity-10 pointer-events-none"></div>

                        <!-- Lens Housing (The black part) -->
                        <div class="relative w-[88px] h-[88px] bg-[#050505] rounded-full border-[2.5px] border-[#111] shadow-[inset_0_0_20px_black,0_1px_1.5px_rgba(255,255,255,0.5)] flex items-center justify-center bg-[radial-gradient(circle_at_40%_40%,#1a1a1a_0%,#000_100%)]">
                            
                            <!-- Lens Glass Effects -->
                            <div class="absolute top-[15%] left-[15%] w-[45%] h-[35%] bg-gradient-to-br from-white/35 to-transparent rounded-[50%] blur-[1.5px] rotate-[-25deg] opacity-70"></div>
                            <div class="absolute top-2.5 left-3.5 w-3.5 h-3.5 bg-white/45 rounded-full blur-[1px]"></div>

                            <!-- Inner Optic (Deep sensor look) -->
                            <div class="w-[54px] h-[54px] bg-[#020202] rounded-full border border-zinc-800 shadow-[inset_0_0_12px_rgba(0,80,255,0.2),0_0_3px_rgba(255,255,255,0.2)] relative overflow-hidden">
                                <div class="absolute top-2 left-2 w-4 h-4 bg-[#3366ff] rounded-full blur-[4px] opacity-10"></div>
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <div class="w-2.5 h-2.5 bg-black rounded-full border border-white/10 shadow-[0_0_5px_rgba(0,200,255,0.4)]"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- BACK FACE: Plastic Texture -->
                <div class="absolute inset-0 flex items-center justify-center rounded-full bg-[#1e1f21] backface-hidden" style="transform: rotateY(180deg);">
                    <div class="w-[120px] h-[120px] rounded-full shadow-[inset_-4px_-6px_20px_rgba(0,0,0,0.6)]"></div>
                    <div class="absolute inset-0 rounded-full pointer-events-none plastic-grain opacity-40 mix-blend-overlay"></div>
                </div>

                <!-- Sphere Parting Seam -->
                <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                    <div class="w-full h-[1.5px] bg-black/40 shadow-[0_0.5px_0_rgba(255,255,255,0.06)]"></div>
                </div>
            </div>

            <!-- Interaction Prompt -->
            <div class="absolute -top-12 left-1/2 -translate-x-1/2 bg-black/60 backdrop-blur-md px-3 py-1.5 rounded-full border border-white/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none">
                <span class="text-[8px] font-pixel text-white uppercase tracking-widest">Flip Camera</span>
            </div>

            <!-- Sphere Socket Base (Deeper look) -->
            <div class="absolute bottom-[-20px] w-[210px] h-[95px] bg-[#141516] rounded-[50%] shadow-[inset_0_15px_35px_black] z-[-1] border-b border-black/70"></div>
        </button>
    </div>

    <!-- MAIN CARTRIDGE BODY -->
    <div class="relative w-[340px] sm:w-[360px] h-52 z-20">
        
        <!-- Shoulder Detailing (Using absolute elements to mock the mold) -->
        <div class="absolute -top-[28px] inset-x-[18px] h-[35px] flex justify-between">
            <div class="w-[85px] h-full bg-[#1e1f21] -skew-x-[22deg] rounded-tl-[12px] border-t border-l border-white/5 shadow-[inset_2px_4px_8px_rgba(255,255,255,0.08)]"></div>
            <div class="w-[85px] h-full bg-[#1e1f21] skew-x-[22deg] rounded-tr-[12px] border-t border-r border-white/5 shadow-[inset_-2px_4px_8px_rgba(255,255,255,0.08)]"></div>
        </div>

        <!-- Main Block Body -->
        <div class="relative w-full h-full bg-[#1e1f21] rounded-t-[4px] shadow-[25px_50px_90px_rgba(0,0,0,0.95),inset_4px_6px_20px_rgba(255,255,255,0.08),inset_-8px_-15px_30px_rgba(0,0,0,0.7)] border-x-[18px] border-b-[6px] border-[#0a0a0a] flex flex-col items-center">
            <div class="absolute inset-0 plastic-grain opacity-40 mix-blend-overlay pointer-events-none rounded-t-[4px]"></div>

            <!-- Nintendo Brand Engraving -->
            <div class="mt-2.5 opacity-30 flex flex-col items-center">
                 <span class="text-[5px] font-pixel text-black font-bold uppercase tracking-[0.25em] drop-shadow-[0_1px_0_rgba(255,255,255,0.15)]">Nintendo</span>
            </div>

            <!-- Label Area (The Blue Sticker) -->
            <div class="absolute top-[38px] left-3.5 right-3.5 h-[125px] bg-[#050505] rounded-[4px] p-[2.5px] shadow-[inset_4px_8px_15px_black,0_1px_1px_rgba(255,255,255,0.08)] border border-white/5">
                <div class="w-full h-full bg-gradient-to-b from-[#1e34a1] to-[#0a1554] flex flex-col items-start justify-center px-7 relative overflow-hidden rounded-sm border-[1.5px] border-black/30">
                    
                    <div class="absolute inset-0 opacity-[0.12] sticker-grain pointer-events-none"></div>

                    <div class="text-[7.5px] font-pixel text-white/40 mb-1 uppercase tracking-[0.2em] font-bold drop-shadow-[0_1px_0_rgba(0,0,0,0.4)]">STUDIO</div>
                    <div class="text-[34px] font-pixel text-[#f8f8f8] font-bold tracking-tighter italic uppercase leading-none drop-shadow-[-2px_-2px_1px_rgba(0,0,0,0.85)]">
                        camera
                    </div>

                    <div class="mt-2 flex items-center gap-2 opacity-30">
                        <div class="w-2 h-2 rounded-full border border-white/40 flex items-center justify-center">
                            <div class="w-0.5 h-0.5 bg-white/60 rounded-full"></div>
                        </div>
                        <span class="text-[5px] font-pixel text-white tracking-[0.2em] leading-none uppercase">Digital System</span>
                    </div>

                    <!-- Label Shine -->
                    <div class="absolute inset-0 bg-gradient-to-br from-white/20 via-transparent to-black/40 pointer-events-none"></div>
                    <div class="absolute top-0 right-0 w-40 h-80 bg-white/5 rotate-[32deg] translate-x-12 -translate-y-24 pointer-events-none"></div>
                </div>
            </div>

            <!-- Lower Detail (Grip Lines) -->
            <div class="absolute bottom-5 left-10 right-10 flex flex-col gap-4 opacity-15">
                <div class="w-full h-[2.5px] bg-black shadow-[inset_0_1px_1px_rgba(255,255,255,0.12)] rounded-full"></div>
                <div class="w-full h-[2.5px] bg-black shadow-[inset_0_1px_1px_rgba(255,255,255,0.12)] rounded-full"></div>
            </div>
        </div>
    </div>
</div>



<script>
    import { setupCartridgeLogic } from '../../lib/cartridge-logic';
    setupCartridgeLogic();
</script>


