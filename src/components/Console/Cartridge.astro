---

<div
    id="gb-cartridge"
    class="absolute -top-[160px] left-1/2 -translate-x-1/2 w-[72%] h-64 z-[-2] translate-y-[120px]"
>
    <!-- Ball Assembly (Authentic Sphere on Swivel) -->
    <div
        class="absolute -top-16 left-1/2 -translate-x-1/2 w-48 h-48 z-10 flex flex-col items-center"
    >
        <!-- The Ball (Charcoal with Top Red Accent) -->
        <div
            class="relative w-38 h-38 rounded-full bg-[#2a2b2c] border-[4px] border-black/80 shadow-[15px_20px_45px_rgba(0,0,0,0.7),inset_-8px_-8px_20px_rgba(0,0,0,0.5)] overflow-hidden flex flex-col"
        >
            <!-- Top Accessory Section -->
            <div
                class="w-full h-8 bg-[#cc0000] border-b-2 border-black/50 shadow-inner"
            >
            </div>

            <!-- White lens face -->
            <div
                class="w-full flex-grow flex items-center justify-center relative"
            >
                <div
                    class="w-28 h-28 bg-[#eeeeee] rounded-full border-2 border-black/30 shadow-inner flex items-center justify-center relative"
                >
                    <!-- Lens Glass -->
                    <div
                        class="relative w-18 h-18 bg-[#0a0a0a] rounded-full border-[3px] border-black flex items-center justify-center"
                    >
                        <div
                            class="absolute top-2 left-3 w-6 h-6 bg-white/10 rounded-full blur-[2px]"
                        >
                        </div>
                        <div
                            class="w-8 h-8 bg-black rounded-full border border-zinc-800"
                        >
                        </div>
                    </div>
                </div>
                <!-- Sphere surface highlight -->
                <div
                    class="absolute inset-0 bg-gradient-to-tr from-black/40 via-transparent to-white/5 pointer-events-none"
                >
                </div>
            </div>
        </div>

        <!-- Swivel Base Neck -->
        <div
            class="absolute bottom-6 w-40 h-16 bg-[#232426] rounded-t-[50%] shadow-lg border-b-2 border-black/50 z-[-1]"
        >
        </div>
    </div>

    <!-- Cartridge Body (FRONT LABEL FOCUS) -->
    <div
        class="relative w-full h-44 bg-[#2a2b2e] rounded-t-md shadow-[20px_30px_60px_rgba(0,0,0,0.8),inset_2px_2px_0_rgba(255,255,255,0.05)] border-x-[12px] border-black/60 flex flex-col items-center"
    >
        <!-- THE CHARACTERISTIC LABEL (Fixed position on front face for visibility) -->
        <div
            class="absolute top-10 left-3 right-3 h-24 bg-black/40 rounded-sm p-1.5 shadow-[inset_4px_4px_10px_black]"
        >
            <div
                class="w-full h-full bg-[#cc0000] shadow-xl flex flex-col items-start justify-center px-4 relative overflow-hidden rounded-xs border-b border-black/20"
            >
                <div
                    class="text-[5px] font-pixel text-[#ffffff55] mb-0.5 uppercase tracking-widest font-bold"
                >
                    GAME BOY
                </div>
                <div
                    class="text-[19px] font-pixel text-white font-bold tracking-tighter italic uppercase leading-none drop-shadow-[2px_2px_2px_black]"
                >
                    camera
                </div>

                <!-- High-Gloss Shine -->
                <div
                    class="absolute inset-0 bg-gradient-to-br from-white/25 via-transparent to-black/30 pointer-events-none"
                >
                </div>
            </div>
        </div>

        <!-- Sloped Integrated Shoulders -->
        <div
            class="absolute -top-6 left-[-12px] w-18 h-10 bg-[#2a2b2e] border-l-[12px] border-black/60 -skew-x-[18deg] rounded-tl-lg shadow-lg"
        >
        </div>
        <div
            class="absolute -top-6 right-[-12px] w-18 h-10 bg-[#2a2b2e] border-r-[12px] border-black/60 skew-x-[18deg] rounded-tr-lg shadow-lg"
        >
        </div>

        <!-- Friction Strips -->
        <div
            class="absolute bottom-3 left-10 right-10 flex flex-col gap-2.5 opacity-20"
        >
            <div class="w-full h-[1.5px] bg-white"></div>
            <div class="w-full h-[1.5px] bg-white"></div>
        </div>
    </div>
</div>
