                            <div class="bg-zinc-800" style="width:1px;height:60%"></div>
                            <div class="bg-zinc-800" style="width:4px;height:95%"></div>
                            <div class="bg-zinc-800" style="width:2px;height:70%"></div>
                            <div class="bg-zinc-800" style="width:1px;height:80%"></div>
                            <div class="bg-zinc-800" style="width:3px;height:90%"></div>
                            <div class="bg-zinc-800" style="width:4px;height:65%"></div>
                            <div class="bg-zinc-800" style="width:1px;height:75%"></div>
                            <div class="bg-zinc-800" style="width:2px;height:85%"></div>
                            <div class="bg-zinc-800" style="width:3px;height:100%"></div>
                            <div class="bg-zinc-800" style="width:1px;height:60%"></div>
