---

---

<div id="gb-printer" class="printer-device relative w-[340px]">
    <!-- Printer Main Body (DMG Gray, Heavy with rounded corners) -->
    <div
        class="relative bg-[#c0c0c0] p-8 pt-12 rounded-[12px_12px_50px_12px] shadow-[40px_60px_100px_rgba(0,0,0,0.7),inset_3px_3px_0_rgba(255,255,255,0.4),0_12px_0_#999] border-t-2 border-l-2 border-white/20 border-r-[12px] border-b-[12px] border-black/25"
    >
        <!-- Top Thick Acrylic Roll Cover -->
        <div
            class="relative w-full h-40 bg-[#9ea0a2] rounded-t-xl shadow-[inset_6px_6px_20px_rgba(0,0,0,0.5),inset_-4px_-4px_10px_rgba(255,255,255,0.1)] border-2 border-black/20 mb-8 overflow-visible"
        >
            <!-- The Paper Roll (Visual depth inside) -->
            <div
                class="absolute top-6 left-1/2 translate-x-center w-[85%] h-28 bg-gradient-to-b from-zinc-300 to-zinc-600 rounded-t-2xl opacity-90 overflow-hidden shadow-inner"
            >
                <!-- Gloss on the paper roll -->
                <div
                    class="absolute inset-0 bg-gradient-to-tr from-white/15 to-transparent"
                >
                </div>
            </div>

            <!-- Thick Glass Reflection / Texture -->
            <div
                class="absolute inset-0 bg-[linear-gradient(135deg,rgba(255,255,255,0.1)_0%,transparent_50%,rgba(0,0,0,0.2)_100%)] rounded-t-xl pointer-events-none"
            >
            </div>

            <!-- Paper Output Slot (Dark and Deep) -->
            <div
                class="absolute bottom-0 w-full h-6 bg-[#0a0a0a] shadow-[inset_0_4px_10px_rgba(0,0,0,0.8)] z-10 rounded-b-sm border-t border-white/5"
            >
            </div>

            <!-- Thermal Paper Ejection (Positioned ABOVE the slot with thickness) -->
            <div
                id="printer-paper-roll"
                class="absolute left-1/2 -translate-x-1/2 bottom-4 w-[78%] h-0 transition-[height,transform] duration-[4000ms] ease-linear bg-[#fdfdfd] flex flex-col items-center overflow-hidden z-20 shadow-[0_-15px_40px_rgba(0,0,0,0.5)] origin-bottom border-x border-zinc-200"
            >
                <!-- Top paper edge shadow -->
                <div
                    class="w-full h-6 bg-zinc-100 mb-3 border-b border-zinc-300"
                >
                </div>

                <img
                    id="printer-image"
                    src=""
                    alt="Printed"
                    class="w-[88%] grayscale contrast-[1.6] brightness-110 pixelated shadow-lg border-2 border-zinc-100"
                />

                <div
                    class="mt-6 p-6 text-[7px] font-pixel text-zinc-500 uppercase tracking-[0.2em] text-center leading-loose opacity-60"
                >
                    * Nintendo *<br />
                    Game Boy Printer<br />
                    Digital Imagery System<br />
                    © 1998 Nintendo Co. Ltd.
                </div>

                <!-- Authentic Jagged Edge (Tear strip) -->
                <div
                    class="absolute bottom-0 left-0 right-0 h-4 bg-[linear-gradient(135deg,#fff_25%,transparent_25%),linear-gradient(225deg,#fff_25%,transparent_25%)] bg-[length:10px_10px] z-30 drop-shadow-sm"
                >
                </div>

                <!-- Download Button (Floats over the ticket) -->
                <button
                    id="printer-download-btn"
                    class="mt-6 px-8 py-3 bg-[#8b1a3d] text-white font-pixel text-[9px] rounded shadow-[0_4px_0_#4a0d21,4px_8px_15px_rgba(0,0,0,0.4)] opacity-0 pointer-events-none transition-all duration-500 hover:brightness-110 active:translate-y-1 active:shadow-none"
                >
                    SAVE TO PC
                </button>
            </div>
        </div>

        <!-- Machine Branding (Carved & Stylized) -->
        <div class="flex flex-col items-center mb-12">
            <div
                class="text-[11px] font-pixel text-[#3a3b3c] font-bold italic opacity-40 mb-1 drop-shadow-sm"
            >
                Game Boy
            </div>
            <div
                class="text-[24px] font-pixel text-[#4a4c4e] font-bold italic tracking-tighter drop-shadow-lg scale-y-90"
            >
                printer
            </div>

            <!-- Recessed "Nintendo" Plate (Carved) -->
            <div
                class="mt-6 px-6 py-2 bg-black/5 rounded shadow-[inset_3px_3px_6px_rgba(0,0,0,0.3),1px_1px_0_rgba(255,255,255,0.1)] border border-black/10"
            >
                <span
                    class="text-[10px] font-pixel text-[#5d5a5d] opacity-70 uppercase tracking-[0.3em] font-bold"
                    >Nintendo</span
                >
            </div>
        </div>

        <!-- Functional Buttons (High texture) -->
        <div class="flex justify-between items-center px-8 mb-12">
            <!-- FEED Button -->
            <div class="flex flex-col items-center gap-4">
                <div class="relative group">
                    <div
                        class="absolute inset-0 bg-black/15 rounded-full blur-md translate-y-2 translate-x-1"
                    >
                    </div>
                    <button
                        id="btn-feed"
                        class="relative w-20 h-20 bg-[#8b1a3d] rounded-full shadow-[inset_-4px_-4px_8px_rgba(0,0,0,0.4),inset_4px_4px_8px_rgba(255,255,255,0.1),0_8px_0_#4a0d21,8px_12px_20px_rgba(0,0,0,0.5)] active:translate-y-2 active:shadow-[inset_-2px_-2px_4px_rgba(0,0,0,0.4),0_2px_0_#4a0d21] transition-all flex items-center justify-center font-pixel text-[9px] text-white/40 tracking-widest font-bold"
                    >
                        FEED
                    </button>
                </div>
            </div>

            <!-- POWER Button (Square well) -->
            <div class="flex flex-col items-center gap-4">
                <div class="relative group">
                    <div
                        class="absolute inset-x-0 bottom-0 top-0 bg-black/20 rounded shadow-[inset_4px_4px_8px_rgba(0,0,0,0.5)]"
                    >
                    </div>
                    <button
                        id="btn-power"
                        class="relative w-18 h-18 bg-[#d6d6d6] rounded-sm shadow-[inset_2px_2px_4px_rgba(255,255,255,0.4),inset_-2px_-2px_4px_rgba(0,0,0,0.2),0_6px_0_#999,6px_10px_15px_rgba(0,0,0,0.4)] border-2 border-black/5 active:translate-y-1 active:shadow-none transition-all flex flex-col items-center justify-center gap-2"
                    >
                        <div
                            id="printer-led"
                            class="w-3 h-3 rounded-full bg-red-950 border border-black/40 shadow-inner"
                        >
                        </div>
                        <div class="w-1.5 h-1.5 bg-black/20 rounded-full"></div>
                    </button>
                    <span
                        class="absolute -bottom-10 left-1/2 -translate-x-1/2 text-[8px] font-pixel text-[#5d5a5d] uppercase opacity-50 font-bold tracking-widest"
                        >POWER</span
                    >
                </div>
            </div>
        </div>

        <!-- Cooling Side Grills (Carved) -->
        <div class="flex flex-col gap-3 opacity-15 px-6">
            <div class="w-full h-[2px] bg-black rounded-full shadow-inner">
            </div>
            <div class="w-full h-[2px] bg-black rounded-full shadow-inner">
            </div>
        </div>
    </div>
</div>

<script>
    window.addEventListener("gb-print-start", (e: any) => {
        const { dataUrl } = e.detail;
        const printer = document.getElementById("gb-printer");
        const paper = document.getElementById("printer-paper-roll");
        const img = document.getElementById(
            "printer-image",
        ) as HTMLImageElement;
        const led = document.getElementById("printer-led");
        const downloadBtn = document.getElementById("printer-download-btn");

        if (printer && paper && img && led) {
            img.src = dataUrl;
            paper.style.height = "0px";

            if (downloadBtn) {
                downloadBtn.classList.add("opacity-0", "pointer-events-none");
                (downloadBtn as any).onclick = () => {
                    const link = document.createElement("a");
                    link.download = `gb-print-${Date.now()}.png`;
                    link.href = dataUrl;
                    link.click();
                };
            }

            // Power on LED
            led.classList.remove("bg-red-950");
            led.classList.add("bg-red-600", "shadow-[0_0_12px_red]");

            setTimeout(() => {
                paper.style.height = "420px";
                setTimeout(() => {
                    if (downloadBtn)
                        downloadBtn.classList.remove(
                            "opacity-0",
                            "pointer-events-none",
                        );
                }, 4000);
            }, 600);

            // Reset sequence
            setTimeout(() => {
                led.classList.remove("bg-red-600", "shadow-[0_0_12px_red]");
                led.classList.add("bg-red-950");
                setTimeout(() => {
                    window.dispatchEvent(new CustomEvent("gb-print-end"));
                }, 10000);
            }, 8000);
        }
    });
</script>

<style>
    .pixelated {
        image-rendering: -moz-pixelated;
        image-rendering: pixelated;
    }
    .translate-x-center {
        transform: translateX(-50%);
    }
    .printer-device-shadow {
        filter: drop-shadow(0 30px 50px rgba(0, 0, 0, 0.5));
    }
</style>
