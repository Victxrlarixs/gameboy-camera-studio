                        <div class="absolute inset-0 opacity-[0.2] pointer-events-none mix-blend-multiply bg-[length:100%_4px] bg-[linear-gradient(to_bottom,transparent_50%,rgba(0,0,0,0.05)_50%)]"></div>
                        <div class="absolute inset-0 opacity-10 pointer-events-none mix-blend-overlay print-noise"></div>
                    </div>

<div class="w-full px-5 py-3 border-t border-dashed border-zinc-300 flex flex-col gap-2 mt-3">
                        <div class="flex justify-between items-center">
                            <span class="text-[5px] font-pixel text-zinc-400 uppercase">Date</span>
                            <span id="printer-date" class="text-[5px] font-pixel text-zinc-600 uppercase">--/--/----</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-[5px] font-pixel text-zinc-400 uppercase">Format</span>
                            <span class="text-[5px] font-pixel text-zinc-600 uppercase">160×144 / 8X UP</span>
