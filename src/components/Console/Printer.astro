                            <div class="bg-zinc-800" style="width:1px;height:70%"></div>
                            <div class="bg-zinc-800" style="width:5px;height:100%"></div>
                            <div class="bg-zinc-800" style="width:2px;height:65%"></div>
                            <div class="bg-zinc-800" style="width:3px;height:85%"></div>
