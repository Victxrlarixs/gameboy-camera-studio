---
import "../../styles/components/Printer.css";
---

<div id="gb-printer" class="printer-device relative w-[340px]">
    
    <div
        id="printer-chassis"
        class="matte-plastic relative p-8 pt-12 rounded-[14px_14px_80px_14px] shadow-[40px_50px_80px_rgba(0,0,0,0.8),inset_-8px_-10px_25px_rgba(0,0,0,0.4),inset_6px_8px_20px_rgba(255,255,255,0.7),inset_-20px_-30px_40px_rgba(0,0,0,0.1)] border-t-[2.5px] border-l-[2.5px] border-r-[32px] border-b-[38px] border-solid border-t-white/50 border-l-white/50 border-r-[#8b8d8c] border-b-[#8b8d8c] flex flex-col items-center z-20"
    >
        <div class="absolute -top-[2.5px] -left-[2.5px] -right-[32px] -bottom-[38px] rounded-[16px_16px_85px_16px] pointer-events-none plastic-grain opacity-[0.45] mix-blend-multiply z-[5]"></div>
        <div class="absolute inset-0 rounded-[14px_14px_80px_14px] pointer-events-none plastic-grain opacity-[0.18] mix-blend-overlay z-[5]"></div>

        <div class="absolute top-[48%] -left-[2.5px] -right-[32px] h-[1.5px] bg-black/20 shadow-[0_1px_0_rgba(255,255,255,0.3)] z-10 pointer-events-none border-y border-black/5"></div>
        <div class="absolute top-0 right-[-14px] bottom-0 w-[1px] bg-black/15 shadow-[1px_0_0_rgba(255,255,255,0.4)] z-10 pointer-events-none"></div>

        <div class="absolute top-[75px] left-[-4px] w-[8px] h-[36px] bg-[#8c8e8d] shadow-[inset_-1px_0_4px_rgba(255,255,255,0.4),inset_1px_1px_3px_rgba(0,0,0,0.5)] border-[0.5px] border-black/20 flex items-center justify-center rounded-r-sm z-10">
            <div class="w-[3px] h-[70%] bg-black/40 rounded-full shadow-[inset_1px_1px_2px_black]"></div>
        </div>

        <div class="absolute top-[130px] right-[-14px] w-[10px] flex flex-col gap-[3.5px] z-10 opacity-70">
            {[...Array(8)].map(() => (
                <div class="w-full h-[2.5px] bg-[#919392] rounded-l-[1px] shadow-[inset_-1px_1px_2px_rgba(0,0,0,0.8),inset_0_-1px_1px_rgba(255,255,255,0.4)]"></div>
            ))}
        </div>

        <!-- Paper Cover Container -->
        <div
            class="relative w-full h-42 bg-[#8c8e8f] rounded-t-[18px] shadow-[inset_12px_12px_25px_rgba(0,0,0,0.8),inset_-4px_-4px_10px_rgba(255,255,255,0.2),0_1px_2px_black/20] border-[2px] border-black/40 mb-8 overflow-visible z-20"
        >
            <div class="absolute inset-x-0 top-[45%] h-[1px] bg-black/20 shadow-[0_1px_0_rgba(255,255,255,0.1)]"></div>
            
            <div class="absolute -top-7 left-1/2 -translate-x-1/2 w-20 h-4 flex flex-col items-center opacity-30">
                <div class="w-full h-[1.5px] bg-black/40 rounded-full mb-1 shadow-[0_0.5px_0_white/40]"></div>
                <span class="text-[5px] font-pixel text-black font-bold tracking-[0.3em] uppercase">PUSH</span>
            </div>
            
            <div
                class="absolute top-8 left-1/2 -translate-x-1/2 w-[85%] h-28 bg-gradient-to-b from-zinc-400 via-zinc-600 to-[#111] rounded-t-[30px] opacity-95 overflow-hidden shadow-[inset_0_20px_30px_rgba(0,0,0,0.5),0_1px_1px_rgba(255,255,255,0.4)] border-t-[2px] border-white/20"
            >
                <div class="absolute inset-0 opacity-20 roll-grain"></div>
                
                <div
                    class="absolute inset-0 bg-gradient-to-tr from-white/10 to-transparent"
                >
                </div>
            </div>

            <div
                class="absolute inset-0 bg-[linear-gradient(135deg,rgba(255,255,255,0.2)_0%,transparent_40%,rgba(255,255,255,0.05)_50%,rgba(0,0,0,0.3)_100%)] rounded-t-2xl pointer-events-none border-b border-black/40"
            >
            </div>

            <div
                class="absolute bottom-0 w-full h-8 bg-[#080808] shadow-[inset_0_6px_15px_black] z-10 rounded-b-sm border-t border-white/5"
            >
                <div class="absolute top-0 inset-x-4 h-[1px] bg-zinc-700/50">
                </div>
            </div>

            <div
                class="absolute inset-x-0 bottom-4 flex justify-center pointer-events-none z-50"
            >
                <div
                    id="printer-paper-roll"
                    class="w-[78%] h-0 transition-[height] duration-[5000ms] cubic-bezier(0.4, 0, 0.2, 1) bg-[#f4f4ec] flex flex-col items-center overflow-hidden shadow-[0_-15px_45px_rgba(0,0,0,0.5),inset_0_-20px_40px_rgba(0,0,0,0.05)] origin-bottom border-x border-zinc-300 rounded-b-sm relative pointer-events-auto cylindrical-shadow"
                >
                    <div class="absolute inset-0 opacity-100 pointer-events-none paper-grain"></div>
                    <div class="absolute inset-0 opacity-100 pointer-events-none paper-curve-effect"></div>

                    <div id="thermal-reveal-container" class="relative w-[88%] shadow-[0_12px_25px_rgba(0,0,0,0.15)] my-2 overflow-hidden">
                        <div id="printer-burn-line" class="burn-line"></div>
                        <img
                            id="printer-photo"
                            src=""
                            class="w-full h-auto pixelated block thermal-reveal"
                            alt="Printed photo"
                        />
                    </div>
                    <div class="absolute inset-0 opacity-[0.2] pointer-events-none mix-blend-multiply bg-[length:100%_4px] bg-[linear-gradient(to_bottom,transparent_50%,rgba(0,0,0,0.05)_50%)]"></div>
                    <div class="absolute inset-0 opacity-10 pointer-events-none mix-blend-overlay print-noise"></div>
                    

                    <div
                        class="absolute bottom-0 left-0 right-0 h-5 z-30"
                        style="background-image: linear-gradient(135deg, #f4f4ec 25%, transparent 25%), linear-gradient(225deg, #f4f4ec 25%, transparent 25%); background-size: 10px 10px; background-repeat: repeat-x; background-position: 0 top;"
                    ></div>
                </div>
            </div>
        </div>

        <div
            class="flex flex-col items-center mb-14 drop-shadow-[0_1px_0_rgba(255,255,255,0.5)] z-20 relative"
        >
            <div class="flex items-center gap-2 mb-1 opacity-70">
                <span class="text-transparent bg-clip-text bg-gradient-to-b from-[#302080] to-[#1a1155] font-bold text-[10px] tracking-tight drop-shadow-[0_0.5px_0_rgba(255,255,255,0.3)]">Nintendo</span>
                <span class="text-[7px] font-pixel text-[#302080]/80 font-bold uppercase tracking-widest">Printer</span>
            </div>
            
            <div
                class="text-[28px] font-pixel text-transparent bg-clip-text bg-gradient-to-b from-[#3a3b3c] to-[#111] font-bold italic tracking-tighter scale-y-95 drop-shadow-[-1px_-1px_0_rgba(0,0,0,0.3)] opacity-90"
            >
                GAME BOY
            </div>
        </div>

        <div class="flex justify-between items-center px-8 mb-14 w-full">
            <!-- FEED Button -->
            <div class="flex flex-col items-center gap-3">
                <div class="relative group">
                    <div class="absolute inset-0 bg-black/40 rounded-full blur-lg translate-y-4 opacity-70 group-active:opacity-40"></div>
                    <button
                        id="btn-feed"
                        class="relative w-[70px] h-[70px] bg-[var(--gb-button-magenta)] rounded-full shadow-[inset_-4px_-6px_10px_rgba(0,0,0,0.7),inset_4px_6px_10px_rgba(255,100,200,0.5),0_12px_20px_rgba(0,0,0,0.8),0_12px_0_#7a0b3c] hover:translate-y-[-1px] hover:brightness-105 active:translate-y-[8px] active:shadow-[inset_-2px_-3px_5px_rgba(0,0,0,0.8),inset_2px_3px_5px_rgba(255,100,200,0.2),0_4px_8px_rgba(0,0,0,0.8),0_4px_0_#7a0b3c] active:brightness-95 transition-all duration-[100ms] border-[0.5px] border-black/20"
                    ></button>
                </div>
                <span class="text-[10px] font-pixel text-[#302080]/60 uppercase font-bold tracking-[0.15em] drop-shadow-[0_1px_0_rgba(255,255,255,0.4)]">BACK</span>
            </div>

            <!-- Cut/Tear Section -->
            <div class="flex flex-col items-center gap-3">
                <div class="relative">
                    <div class="absolute inset-x-[-10px] inset-y-[-10px] bg-black/15 rounded-xl shadow-[inset_4px_8px_15px_rgba(0,0,0,0.6),1px_2px_0_rgba(255,255,255,0.5)] border border-black/5"></div>
                    
                    <div class="relative w-20 h-20 bg-[#c0c2c3] rounded shadow-[inset_2px_2px_4px_rgba(255,255,255,0.5),inset_-2px_-2px_4px_rgba(0,0,0,0.2),12px_18px_25px_rgba(0,0,0,0.6)] border-[0.5px] border-black/20 overflow-hidden flex flex-col items-center justify-center gap-2">
                        <div class="absolute inset-0 plastic-grain opacity-10 pointer-events-none"></div>
                        
                        <div
                            id="printer-led"
                            class="w-5 h-5 rounded-full bg-[#3a0000] border-[1.5px] border-black/80 shadow-[inset_1px_2px_4px_black,0_1px_1px_rgba(255,255,255,0.4)] z-10 transition-colors duration-200"
                        >
                            <div class="absolute top-[20%] left-[20%] w-[30%] h-[30%] bg-white/20 rounded-full blur-[1px]"></div>
                        </div>

                        <div class="h-[1px] w-10 bg-black/30 rounded-full"></div>

                        <div class="flex flex-col items-center">
                             <span class="text-[6px] font-pixel text-zinc-700 uppercase tracking-tighter opacity-80">Press to</span>
                             <span class="text-[7px] font-pixel text-[#a01050] font-bold uppercase tracking-tight">CUT</span>
                        </div>
                    </div>
                    <button id="btn-cut" class="absolute inset-0 opacity-0 cursor-pointer z-20"></button>
                    <!-- Visual overlay for active state -->
                    <div class="absolute inset-0 pointer-events-none rounded transition-all duration-75 group-active:bg-black/10"></div>
                </div>
                <span class="text-[10px] font-pixel text-[#302080]/60 uppercase font-bold tracking-[0.15em] drop-shadow-[0_1px_0_rgba(255,255,255,0.4)]">TEAR OFF</span>
            </div>
        </div>
    </div>

    <!-- Thermal Preview Overlay -->
    <div
        id="thermal-preview-overlay"
        class="fixed inset-0 z-[200] flex items-center justify-center opacity-0 pointer-events-none transition-all duration-700"
    >
        <div class="absolute inset-0 bg-[#0a0a0c]">
            <div class="absolute inset-x-0 top-0 h-[70%] bg-[radial-gradient(ellipse_60%_50%_at_50%_0%,rgba(248,240,200,0.07)_0%,transparent_100%)] pointer-events-none"></div>
        </div>

        <div id="ticket-drop" class="relative flex flex-col items-center z-10 translate-y-[-20px] opacity-0 transition-all duration-700 ease-out">
            <div id="torn-paper"
                class="relative flex flex-col items-center bg-[#f4f4ec] shadow-[0_60px_120px_rgba(0,0,0,0.9),0_20px_40px_rgba(0,0,0,0.6)] w-[90vw] max-w-[420px] sm:w-[420px] cylindrical-shadow"
                style="rotate: -0.6deg;"
            >
                <div class="absolute inset-x-0 top-4 bottom-4 pointer-events-none paper-grain z-10"></div>
                <div class="absolute inset-x-0 top-4 bottom-4 pointer-events-none paper-curve-effect z-10"></div>
                <div class="w-full h-4 overflow-hidden flex-shrink-0"
                    style="background-image: linear-gradient(135deg, transparent 33.33%, #f7f5ee 33.33%), linear-gradient(225deg, transparent 33.33%, #f7f5ee 33.33%); background-size: 8px 8px; background-position: 0 bottom; background-repeat: repeat-x;"
                ></div>

                <div class="w-full px-5 py-6 relative">
                    <div class="relative w-full shadow-[0_12px_25px_rgba(0,0,0,0.15)]">
                        <img id="preview-image" alt="Thermal printed photo preview" src="" class="w-full pixelated contrast-[1.1] brightness-[1.05] border border-black/5" />
                        
                        <div class="absolute inset-0 opacity-[0.2] pointer-events-none mix-blend-multiply bg-[length:100%_4px] bg-[linear-gradient(to_bottom,transparent_50%,rgba(0,0,0,0.05)_50%)]"></div>
                        <div class="absolute inset-0 opacity-10 pointer-events-none mix-blend-overlay print-noise"></div>
                    </div>
                </div>

                <div class="w-full h-4 overflow-hidden flex-shrink-0"
                    style="background-image: linear-gradient(315deg, transparent 33.33%, #f7f5ee 33.33%), linear-gradient(45deg, transparent 33.33%, #f7f5ee 33.33%); background-size: 8px 8px; background-position: 0 top; background-repeat: repeat-x;"
                ></div>

                <div class="absolute inset-0 pointer-events-none paper-grain opacity-[0.04]"></div>
                <div class="absolute inset-y-0 left-[30%] w-[1px] bg-black/[0.03] pointer-events-none"></div>
                <div class="absolute inset-y-0 right-[25%] w-[1px] bg-black/[0.03] pointer-events-none"></div>
            </div>

            <div class="flex gap-10 mt-10">
                <div class="flex flex-col items-center gap-4">
                    <button id="confirm-download-btn"
                        class="w-20 h-20 bg-[#a01050] rounded-full shadow-[inset_-4px_-4px_10px_rgba(0,0,0,0.5),inset_3px_3px_8px_rgba(255,255,255,0.2),0_10px_0_#7a0b3c,0_20px_40px_rgba(0,0,0,0.7)] hover:translate-y-[-2px] hover:brightness-110 hover:shadow-[inset_-4px_-4px_10px_rgba(0,0,0,0.5),inset_3px_3px_8px_rgba(255,255,255,0.3),0_10px_0_#7a0b3c,0_25px_50px_rgba(0,0,0,0.8)] active:translate-y-[8px] active:shadow-[inset_-2px_-2px_4px_rgba(0,0,0,0.6),0_2px_0_#7a0b3c,0_10px_20px_rgba(0,0,0,0.6)] active:brightness-95 transition-all duration-[150ms] ease-out flex items-center justify-center">
                        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.9)" stroke-width="2.5" stroke-linecap="round">
                            <path d="M12 4v12M6 14l6 6 6-6"/>
                        </svg>
                    </button>
                    <span class="text-[9px] font-pixel text-zinc-300 uppercase tracking-widest">Export</span>
                </div>

                <div class="flex flex-col items-center gap-4">
                    <button id="share-photo-btn"
                        class="w-20 h-20 bg-[#302080] rounded-full shadow-[inset_-4px_-4px_10px_rgba(0,0,0,0.5),inset_3px_3px_8px_rgba(255,255,255,0.15),0_10px_0_#1a1050,0_20px_40px_rgba(0,0,0,0.7)] hover:translate-y-[-2px] hover:brightness-110 hover:shadow-[inset_-4px_-4px_10px_rgba(0,0,0,0.5),inset_3px_3px_8px_rgba(255,255,255,0.25),0_10px_0_#1a1050,0_25px_50px_rgba(0,0,0,0.8)] active:translate-y-[8px] active:shadow-[inset_-2px_-2px_4px_rgba(0,0,0,0.6),0_2px_0_#1a1050,0_10px_20px_rgba(0,0,0,0.6)] active:brightness-95 transition-all duration-[150ms] ease-out flex items-center justify-center">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.85)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                        </svg>
                    </button>
                    <span class="text-[9px] font-pixel text-zinc-300 uppercase tracking-widest">Share</span>
                </div>

                <div class="flex flex-col items-center gap-4">
                    <button id="cancel-preview-btn"
                        class="w-20 h-20 bg-zinc-700 rounded-full shadow-[inset_-4px_-4px_10px_rgba(0,0,0,0.5),inset_3px_3px_8px_rgba(255,255,255,0.08),0_10px_0_rgba(0,0,0,0.6),0_20px_40px_rgba(0,0,0,0.7)] hover:translate-y-[-2px] hover:brightness-110 hover:shadow-[inset_-4px_-4px_10px_rgba(0,0,0,0.5),inset_3px_3px_8px_rgba(255,255,255,0.15),0_10px_0_rgba(0,0,0,0.6),0_25px_50px_rgba(0,0,0,0.8)] active:translate-y-[8px] active:shadow-[inset_-2px_-2px_4px_rgba(0,0,0,0.6),0_2px_0_rgba(0,0,0,0.6),0_10px_20px_rgba(0,0,0,0.6)] active:brightness-95 transition-all duration-[150ms] ease-out flex items-center justify-center">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="2.5" stroke-linecap="round">
                            <path d="M18 6L6 18M6 6l12 12"/>
                        </svg>
                    </button>
                    <span class="text-[9px] font-pixel text-zinc-500 uppercase tracking-widest">Eject</span>
                </div>
            </div>
        </div>
    </div>

    <script>
        import { setupPrinterLogic } from "../../lib/printer-logic";
        setupPrinterLogic();
    </script>
</div>
