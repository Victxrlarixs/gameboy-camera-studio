---
import GameBoyScreen from "./Screen.astro";
import GameBoyControls from "./Controls.astro";
import Printer from "./Printer.astro";
import Cartridge from "./Cartridge.astro";
import StudioSidePanel from "../Interface/StudioSidePanel.astro";
import ServiceManualPanel from "../Interface/ServiceManualPanel.astro";
import LabBook from "../Interface/LabBook.astro";
import "../../styles/components/GameBoy.css";
---

<div id="studio-layout" class="flex w-full h-full gap-8 overflow-hidden">
    
    <div class="hidden xl:flex h-full items-center">
        <StudioSidePanel />
    </div>

    <div id="perspective-container" class="flex-1 flex items-center justify-center perspective-[2000px]">
        <div id="hardware-scaler" class="opacity-0 transition-opacity duration-300 ease-in-out">
            <div id="hardware-hub" class="relative transition-transform duration-300 ease-out preserve-3d">
                
                <div id="camera-unit" class="flex flex-col items-center relative z-10">
                    <div id="cartridge-wrapper" class="cartridge-land">
                        <Cartridge />
                    </div>

<div
                    id="gb-chassis"
                    class="matte-plastic relative w-[480px] sm:w-[500px] p-6 sm:p-8 pt-10 sm:pt-12 pb-6 sm:pb-8 rounded-[14px_14px_220px_14px] shadow-[25px_30px_45px_rgba(0,0,0,0.8),inset_-6px_-10px_20px_rgba(0,0,0,0.4),inset_4px_6px_15px_rgba(255,255,255,0.7),inset_-15px_-25px_30px_rgba(0,0,0,0.15)] border-t-[2px] border-l-[2px] border-r-[20px] border-b-[28px] border-solid border-t-white/60 border-l-white/60 border-r-[#8b8d8c] border-b-[#8b8d8c] flex flex-col items-center z-20"
                >
                    <!-- Texture Overlay extended to cover the 3D fake borders for side realism -->
                    <div class="absolute -top-[2px] -left-[2px] -right-[20px] -bottom-[28px] rounded-[16px_16px_225px_16px] pointer-events-none plastic-grain opacity-[0.5] mix-blend-multiply z-[5]"></div>
                    <div class="absolute inset-0 rounded-[14px_14px_220px_14px] pointer-events-none plastic-grain opacity-[0.2] mix-blend-overlay z-[5]"></div>

                    <!-- Top Power Switch -->
                    <div class="absolute top-[32px] inset-x-0 h-[2px] bg-black/15 shadow-[0_1px_0_rgba(255,255,255,0.4)] pointer-events-none z-10">
                        <div class="absolute left-[30px] top-[-6px] w-[100px] h-[14px] rounded-full shadow-[inset_1px_3px_5px_rgba(0,0,0,0.5),0_1px_1px_rgba(255,255,255,0.6)] flex items-center px-3 gap-2 overflow-hidden bg-[#9c9e9d] border-[1.5px] border-black/10">
                            <!-- Engraved text -->
                            <span class="text-[4px] text-black/50 font-bold uppercase tracking-widest font-pixel drop-shadow-[0_1px_0_rgba(255,255,255,0.4)] whitespace-nowrap">◀ OFF•ON ▶</span>
                            <!-- Mechanical slider switch -->
                            <div class="absolute right-[0px] top-0 bottom-0 w-[40px] bg-[#a8a9aa] shadow-[inset_2px_2px_4px_rgba(255,255,255,0.6),inset_-2px_-2px_4px_rgba(0,0,0,0.2),-2px_0_4px_rgba(0,0,0,0.4)] flex justify-evenly items-center px-1">
                                {[...Array(3)].map(() => <div class="w-[3px] h-[8px] bg-black/10 rounded-full shadow-[inset_1px_0_2px_rgba(255,255,255,0.5),inset_-1px_0_2px_rgba(0,0,0,0.2)]"></div>)}
                            </div>
                        </div>
                    </div>

                    <!-- Right Side Outer Vents -->
                    <div class="absolute top-[35px] right-[-14px] w-[10px] flex flex-col gap-[3.5px] z-20 opacity-80">
                        {[...Array(6)].map((_, i) => (
                            <div class="w-full h-[2.5px] bg-[#111] shadow-[inset_1px_1px_2px_black,0_1px_1px_rgba(255,255,255,0.4)] rounded-l-[1px]"></div>
                        ))}
                    </div>

                    <!-- Right Side Shell Parting Seam -->
                    <div class="absolute top-[10px] right-[-10px] bottom-[150px] w-[2px] bg-black/20 shadow-[1px_0px_1px_rgba(255,255,255,0.5),inset_1px_0_2px_rgba(0,0,0,0.5)] z-20 pointer-events-none rounded-full"></div>

                    <!-- Left Side Grip Grooves (Lower Half) -->
                    <div class="absolute bottom-[20px] left-[-4px] w-[6px] flex flex-col gap-[3.5px] z-30 opacity-70">
                        {[...Array(25)].map((_, i) => (
                            <div class="w-full h-[2.5px] bg-[#919392] rounded-r-sm shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),inset_0_-1px_1px_rgba(255,255,255,0.4)]"></div>
                        ))}
                    </div>

                    <!-- Left Side Grip Grooves (Upper Half) -->
                    <div class="absolute top-[85px] left-[-4px] w-[6px] flex flex-col gap-[3.5px] z-30 opacity-70">
                        {[...Array(8)].map((_, i) => (
                            <div class="w-full h-[2.5px] bg-[#919392] rounded-r-sm shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),inset_0_-1px_1px_rgba(255,255,255,0.4)]"></div>
                        ))}
                    </div>

                    <!-- EXT CONNECTOR Port -->
                    <div class="absolute top-[20px] left-[-4px] w-[8px] h-[45px] bg-[#8c8e8d] shadow-[inset_-1px_0_4px_rgba(255,255,255,0.4),inset_1px_1px_3px_rgba(0,0,0,0.5)] border-[0.5px] border-black/20 flex items-center justify-center rounded-r-sm z-10">
                       <span class="text-[3px] text-[#444] font-bold uppercase rotate-[-90deg] font-sans tracking-tight whitespace-nowrap opacity-70 translate-x-[0.5px]">EXT.CONN.</span>
                    </div>

                    <!-- Left Side Contrast Wheel Bevel -->
                    <div class="absolute left-[-14px] top-[140px] w-[16px] h-[55px] bg-[#1a1b1d] rounded-r-none rounded-l-[10px] shadow-[inset_4px_2px_8px_rgba(0,0,0,0.9),inset_0_-2px_4px_rgba(255,255,255,0.2),2px_5px_8px_rgba(0,0,0,0.7)] z-10 overflow-hidden flex flex-col items-center justify-center border-y-2 border-[#111]">
                        <div class="absolute inset-0 plastic-grain opacity-50 mix-blend-overlay pointer-events-none"></div>
                        <div id="contrast-wheel" class="relative w-[22px] h-[70px] bg-[#111] translate-x-[-3px] shadow-[inset_4px_0_10px_black] border-y-[4px] border-[#0a0a0a] rounded-[50%] flex flex-col items-center justify-around py-3 cursor-ns-resize touch-none">
                            <span class="absolute right-[18px] top-1/2 translate-x-full text-[4px] font-pixel text-[#666] font-bold tracking-widest uppercase rotate-[-90deg] pointer-events-none whitespace-nowrap">CONTRAST</span>
                            <div id="contrast-grooves" class="absolute inset-0 flex flex-col justify-evenly py-2 pointer-events-none transition-transform duration-75">
                                {[...Array(12)].map((_, i) => (
                                    <div class="w-full h-[2px] bg-[#222] shadow-[0_1px_1px_black] pointer-events-none opacity-80"></div>
                                ))}
                            </div>
                        </div>
                    </div>

                    <!-- Right Side Volume Wheel Housing Bevel -->
                    <div class="absolute right-[0px] top-[108px] w-[6px] h-[62px] bg-[#0000000a] rounded-full shadow-[inset_-3px_0_8px_rgba(0,0,0,0.3),1px_1px_1px_rgba(255,255,255,0.5)] z-10"></div>
                    <!-- Right Side Volume Wheel -->
                    <div class="absolute right-[-28px] top-[110px] w-[20px] h-[58px] bg-[#1a1b1d] rounded-l-none rounded-r-[8px] shadow-[inset_0_4px_10px_rgba(0,0,0,0.8),-3px_5px_10px_rgba(0,0,0,0.5)] z-10 overflow-hidden flex flex-col items-center justify-center border-y-[3px] border-[#111]">
                        <div class="absolute inset-0 plastic-grain opacity-50 mix-blend-overlay pointer-events-none"></div>
                        <div id="volume-wheel" class="relative w-[28px] h-[75px] bg-[#0c0c0c] translate-x-[4px] shadow-[inset_-4px_0_10px_black] border-y-[5px] border-[#0a0a0a] rounded-[50%] flex flex-col items-center justify-evenly py-3 cursor-ns-resize touch-none">
                            <span class="absolute left-[28px] top-1/2 -translate-x-full text-[4px] font-pixel text-[#666] font-bold tracking-widest uppercase rotate-[90deg] pointer-events-none whitespace-nowrap">VOLUME</span>
                            <div id="volume-grooves" class="absolute inset-0 flex flex-col justify-evenly py-2 pointer-events-none transition-transform duration-75">
                                {[...Array(12)].map((_, i) => (
                                    <div class="w-full h-[2px] bg-[#222] shadow-[0_1px_1px_black] pointer-events-none opacity-80"></div>
                                ))}
                            </div>
                        </div>
                    </div>
                    


                    <div class="w-[92%] p-5 sm:p-7 pt-5 pb-8 sm:pb-12 bg-[#656668] rounded-[10px_10px_50px_10px] shadow-[inset_1px_2px_15px_rgba(0,0,0,0.8),inset_-1px_-1px_3px_rgba(255,255,255,0.2),0_1px_0_rgba(255,255,255,0.6),0_0_0_2.5px_#2c2d2e] mt-6 mb-8 relative flex flex-col items-center z-20">
                        <div class="absolute inset-0 rounded-[10px_10px_50px_10px] plastic-grain opacity-[0.15] pointer-events-none mix-blend-multiply z-10"></div>
                        <div class="absolute inset-0 rounded-[10px_10px_50px_10px] pointer-events-none z-40 shadow-[inset_1px_2px_4px_rgba(255,255,255,0.1),inset_-2px_-4px_8px_rgba(0,0,0,0.15)] bg-gradient-to-tr from-transparent via-[rgba(255,255,255,0.03)] to-transparent"></div>

                        <!-- Red Battery Light -->
                        <div class="absolute left-6 top-[32%] flex flex-col items-center gap-1.5 pointer-events-none z-30">
                            <div id="power-led" class="w-2.5 h-2.5 rounded-full bg-red-950 border-[0.5px] border-black/80 shadow-[inset_1px_1px_3px_black,0_0_6px_rgba(255,0,0,0.2)]"></div>
                            <span class="text-[5.5px] text-[#b4b5b6] font-medium font-sans uppercase tracking-widest opacity-80 scale-x-90 translate-x-[-1px]">BATTERY</span>
                        </div>

                        <!-- Top Decorator Lines -->
                        <div class="flex items-center justify-center w-[90%] mb-4 relative z-20">
                            <!-- Left Lines -->
                            <div class="flex flex-col gap-[2px] flex-1 translate-y-[1px]">
                                <div class="h-[1.5px] w-full bg-[#8a1d4b] rounded-l-full shadow-[0_0.5px_0_rgba(255,255,255,0.15)]"></div>
                                <div class="h-[1.5px] w-full bg-[#261f65] rounded-l-full shadow-[0_0.5px_0_rgba(255,255,255,0.15)]"></div>
                            </div>
                            <!-- Center Text -->
                            <div class="text-[6px] sm:text-[6.5px] text-[#c2c3c4] font-bold font-sans uppercase whitespace-nowrap tracking-[0.08em] px-3 drop-shadow-[0_1px_0_rgba(0,0,0,0.9)] opacity-90 pb-[1.5px]">
                                DOT MATRIX WITH STEREO SOUND
                            </div>
                            <!-- Right Lines -->
                            <div class="flex flex-col gap-[2px] flex-1 translate-y-[1px]">
                                <div class="h-[1.5px] w-full bg-[#8a1d4b] rounded-r-full shadow-[0_0.5px_0_rgba(255,255,255,0.15)]"></div>
                                <div class="h-[1.5px] w-full bg-[#261f65] rounded-r-full shadow-[0_0.5px_0_rgba(255,255,255,0.15)]"></div>
                            </div>
                        </div>


                        <div id="lcd-container" class="relative w-full max-w-[340px] sm:max-w-[350px] aspect-square bg-[#9bbc0f] border-x-[16px] border-b-[24px] border-t-[14px] sm:border-x-[20px] sm:border-b-[28px] sm:border-t-[16px] border-[#0e0e0e] rounded-[10px] shadow-[inset_0_0_80px_rgba(0,0,0,0.9),inset_4px_6px_20px_black,0_2px_1px_rgba(255,255,255,0.2)] overflow-hidden transition-all duration-500 z-20 mt-1" style="filter: brightness(1) contrast(1);">

                                <div class="absolute inset-0 pixel-grid z-20"></div>
                                
                                <div id="lcd-glare" class="absolute inset-0 z-30 opacity-40 pointer-events-none transition-transform duration-100 ease-out mix-blend-screen" style="background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0.05) 50%, transparent 70%);"></div>
                                <div class="absolute inset-0 z-[35] opacity-20 pointer-events-none" style="background: linear-gradient(135deg, rgba(255,255,255,0.4) 0%, transparent 40%, transparent 60%, rgba(0,0,0,0.6) 100%);"></div>

                                <GameBoyScreen />
                            </div>
                    </div>

                    <div class="w-full px-12 mb-8 select-none text-center relative z-20 flex justify-center items-end gap-1">
                        <span class="text-transparent bg-clip-text bg-gradient-to-b from-[#302080] to-[#1a1155] font-bold text-[18px] tracking-tight opacity-90 drop-shadow-[0_1px_0_rgba(255,255,255,0.4)] drop-shadow-[0_-1px_0_rgba(0,0,0,0.2)] leading-none mb-[2px]">Nintendo</span>
                        <span class="text-transparent bg-clip-text bg-gradient-to-b from-[#302080] to-[#1a1155] font-bold italic text-2xl sm:text-3xl tracking-tighter opacity-90 drop-shadow-[0_1px_1px_rgba(255,255,255,0.5)] drop-shadow-[0_-1px_1px_rgba(0,0,0,0.2)] leading-none pr-1">GAME BOY<span class="text-[10px] align-bottom font-normal font-pixel ml-1 uppercase absolute bottom-[4px]">TM</span></span>
                    </div>


<div class="w-full px-8 mb-4">
                        <GameBoyControls />
                    </div>



                        <!-- Speaker / Ventilation Grille (Deeply recessed with plastic ribbing) -->
                        <div class="absolute bottom-[55px] right-[40px] flex gap-[6.5px] opacity-90 z-20 rotate-[-28deg] origin-bottom">
                            {[...Array(6)].map((_, i) => (
                                <div class="w-[6px] h-[45px] bg-[#111] rounded-full shadow-[inset_4px_4px_6px_black,inset_-1px_-1px_2px_rgba(255,255,255,0.1),1px_1px_0_rgba(255,255,255,0.9)] overflow-hidden relative border-[0.5px] border-black/40">
                                   <!-- Inner Shadow Depth -->
                                   <div class="absolute top-0 right-0 w-[2px] h-full bg-black"></div>
                                </div>
                            ))}
                        </div>

                        <!-- Bottom Curve Horizontal Ventilation Grooves -->
                        <div class="absolute bottom-[-16px] left-[65px] flex gap-[4px] opacity-80 z-20">
                            {[...Array(6)].map((_, i) => (
                                <div class="w-[3px] h-[12px] bg-[#111] rounded-[2px] shadow-[inset_1px_2px_3px_black,0_1px_1px_rgba(255,255,255,0.6)]"></div>
                            ))}
                        </div>

                        <!-- Bottom Left Strap Hole Bevel -->
                        <div class="absolute bottom-[-15px] left-[15px] w-[14px] h-[8px] bg-black/30 rounded-full shadow-[inset_2px_3px_5px_black,0_1px_1px_rgba(255,255,255,0.8)] border-b border-white/40"></div>
                        <div class="absolute bottom-[-5px] left-[20px] w-[4px] h-[10px] bg-black/60 rounded-full shadow-[inset_1px_1px_2px_black]"></div>

                        <!-- Outer PHONES Engraving -->
                        <div class="absolute bottom-[20px] left-1/2 -translate-x-1/2 flex flex-col items-center">
                            <div class="w-[85px] h-[34px] border-[0.5px] border-black/15 shadow-[0_1px_0_rgba(255,255,255,0.7),inset_1px_1px_3px_rgba(0,0,0,0.15)] rounded-full flex items-center justify-center relative translate-y-[2px]">
                                <!-- Inner physical gap representation (headphone jack socket) -->
                                <div class="w-[70%] h-[12%] bg-black/40 rounded-full shadow-[inset_1px_1px_3px_black] border-b border-white/50 absolute top-[10px]"></div>
                            </div>
                            
                            <div class="flex items-center gap-1.5 opacity-60 mix-blend-multiply bg-[#a0a3a2] -translate-y-[6px] px-2 relative z-10">
                                <svg class="w-2.5 h-2.5 stroke-black fill-none stroke-[2] drop-shadow-[0_1px_0_rgba(255,255,255,0.3)]" viewBox="0 0 24 24"><path d="M4 12v6a2 2 0 0 0 2 2h2v-8H4zm16 0v6a2 2 0 0 1-2 2h-2v-8h4zM12 4a8 8 0 0 0-8 8m16 0a8 8 0 0 0-8-8"/></svg>
                                <span class="text-[5px] text-black font-bold font-sans uppercase tracking-[0.1em] drop-shadow-[0_1px_0_rgba(255,255,255,0.3)] pr-1">PHONES</span>
                            </div>
                        </div>
                        </div>
                    </div>
                </div>

<div 
                    id="printer-unit" 
                    class="absolute inset-x-0 bottom-0 top-0 flex items-center justify-center pointer-events-none opacity-0 z-[100]"
                >
                    <Printer />
                </div>
            </div>
        </div>
    </div>
    </div>

    <script>
        import { setupGameBoyLogic } from "../../lib/gameboy-logic";
        setupGameBoyLogic();
    </script>

    <div class="hidden xl:flex h-full items-center">
        <ServiceManualPanel />
    </div>

    <LabBook />
</div>
