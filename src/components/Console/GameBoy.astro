---
import GameBoyScreen from "./Screen.astro";
import GameBoyControls from "./Controls.astro";
import Printer from "./Printer.astro";
import Cartridge from "./Cartridge.astro";
---

<div id="hardware-hub" class="relative group">
    <!-- DEVICE A: THE CAMERA UNIT -->
    <div
        id="camera-unit"
        class="relative transition-all duration-700 flex flex-col items-center"
    >
        <!-- AUTHENTIC DMG GAME BOY CHASSIS -->
        <div
            class="relative w-[440px] bg-[var(--gb-gray)] p-8 pt-16 rounded-[12px_12px_120px_12px] shadow-[30px_50px_100px_rgba(0,0,0,0.7),inset_3px_3px_0_rgba(255,255,255,0.4),0_12px_0_#9a9a97] border-t-2 border-l-2 border-white/30 border-r-[12px] border-b-[12px] border-black/30 flex flex-col items-center"
        >
            <!-- Cartridge Slot Depth Effect -->
            <div
                class="absolute -top-7 left-1/2 -translate-x-1/2 w-[74%] h-14 bg-[#1a1a1a] rounded-t-lg z-[-2] shadow-[inset_0_10px_20px_black] border-t-[10px] border-black"
            >
            </div>

            <Cartridge />

            <!-- SCREEN AREA -->
            <div
                class="bg-[#707071] w-full p-8 pt-4 rounded-[12px] shadow-[inset_2px_2px_10px_black] mb-8 relative border-b-2 border-white/5 flex flex-col items-center"
            >
                <!-- Battery LED (Red) -->
                <div
                    class="absolute left-3.5 top-1/2 -translate-y-1/2 flex flex-col items-center gap-2 pointer-events-none"
                >
                    <div
                        id="power-led"
                        class="w-2.5 h-2.5 rounded-full bg-red-950 border border-black/40 shadow-inner"
                    >
                    </div>
                    <span
                        class="text-[7px] text-zinc-400 font-bold uppercase tracking-widest opacity-60"
                        >Battery</span
                    >
                </div>

                <!-- Bezel Decorative Lines -->
                <div class="flex justify-between items-center w-full mb-5 px-1">
                    <div
                        class="h-[2px] grow bg-[#a01050] rounded-full opacity-60"
                    >
                    </div>
                    <div
                        class="text-[8px] text-zinc-300 font-bold uppercase opacity-90 mx-3 font-pixel whitespace-nowrap tracking-tighter shadow-sm"
                    >
                        Dot Matrix with Stereo Sound
                    </div>
                    <div
                        class="h-[2px] grow bg-[#302080] rounded-full opacity-60"
                    >
                    </div>
                </div>

                <!-- THE LCD SCREEN -->
                <div
                    class="relative w-[300px] aspect-square bg-[#9bbc0f] border-[6px] border-[#0f380f] shadow-[inset_0_0_50px_rgba(0,0,0,0.3)] overflow-hidden rounded-sm transition-all duration-500"
                >
                    <GameBoyScreen />
                </div>
            </div>

            <!-- Branding -->
            <div class="w-full px-4 mb-2">
                <span
                    class="text-[#302080] font-bold italic text-2xl tracking-tighter opacity-90"
                    >Nintendo <span class="text-xl"
                        >GAME BOY<span
                            class="text-[9px] align-top font-normal font-pixel ml-1 uppercase"
                            >TM</span
                        ></span
                    ></span
                >
            </div>

            <!-- Controls Area -->
            <div class="w-full">
                <GameBoyControls />
            </div>

            <!-- Speaker Grill -->
            <div
                class="absolute bottom-12 right-10 rotate-[-45deg] flex gap-3 opacity-90"
            >
                <div
                    class="w-3 h-16 bg-black/20 rounded-full shadow-[inset_2px_2px_4px_rgba(0,0,0,0.5)]"
                >
                </div>
                <div
                    class="w-3 h-16 bg-black/20 rounded-full shadow-[inset_2px_2px_4px_rgba(0,0,0,0.5)]"
                >
                </div>
                <div
                    class="w-3 h-16 bg-black/20 rounded-full shadow-[inset_2px_2px_4px_rgba(0,0,0,0.5)]"
                >
                </div>
                <div
                    class="w-3 h-16 bg-black/20 rounded-full shadow-[inset_2px_2px_4px_rgba(0,0,0,0.5)]"
                >
                </div>
                <div
                    class="w-3 h-16 bg-black/20 rounded-full shadow-[inset_2px_2px_4px_rgba(0,0,0,0.5)]"
                >
                </div>
                <div
                    class="w-3 h-16 bg-black/20 rounded-full shadow-[inset_2px_2px_4px_rgba(0,0,0,0.5)]"
                >
                </div>
            </div>

            <!-- Phones Jack Label -->
            <div
                class="absolute bottom-4 left-1/2 -translate-x-1/2 flex flex-col items-center"
            >
                <div
                    class="w-12 h-1.5 bg-black/20 rounded-full shadow-inner mb-1"
                >
                </div>
                <span
                    class="text-[7px] text-[#5d5a5d] uppercase opacity-40 font-bold tracking-widest"
                    >Phones</span
                >
            </div>
        </div>
    </div>

    <!-- DEVICE B: THE PRINTER UNIT -->
    <div
        id="printer-unit"
        class="absolute inset-x-0 bottom-0 top-0 flex items-center justify-center pointer-events-none opacity-0 translate-y-[300px] transition-all duration-1000 transform-gpu z-[100] scale-110"
    >
        <Printer />
    </div>
</div>

<script>
    const cameraUnit = document.getElementById("camera-unit");
    const printerUnit = document.getElementById("printer-unit");
    const powerLed = document.getElementById("power-led");

    window.addEventListener("gb-mode-change", (e: any) => {
        if (e.detail.mode === "SHOOT" && powerLed) {
            powerLed.classList.remove("bg-red-950");
            powerLed.classList.add("bg-red-600", "shadow-[0_0_12px_red]");
        }
    });

    window.addEventListener("gb-print-start", () => {
        if (cameraUnit && printerUnit) {
            cameraUnit.classList.add(
                "opacity-0",
                "-translate-y-[600px]",
                "rotate-[-20deg]",
                "scale-50",
                "pointer-events-none",
            );
            setTimeout(() => {
                printerUnit.classList.remove(
                    "opacity-0",
                    "translate-y-[300px]",
                    "pointer-events-none",
                );
                printerUnit.classList.add("opacity-100", "translate-y-0");
            }, 400);
        }
    });

    window.addEventListener("gb-print-end", () => {
        setTimeout(() => {
            if (cameraUnit && printerUnit) {
                printerUnit.classList.add(
                    "opacity-0",
                    "translate-y-[300px]",
                    "pointer-events-none",
                );
                printerUnit.classList.remove("opacity-100", "translate-y-0");
                setTimeout(() => {
                    cameraUnit.classList.remove(
                        "opacity-0",
                        "-translate-y-[600px]",
                        "rotate-[-20deg]",
                        "scale-50",
                        "pointer-events-none",
                    );
                }, 500);
            }
        }, 3000);
    });
</script>
